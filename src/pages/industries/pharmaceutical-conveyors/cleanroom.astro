    { "@type": "ListItem", "position": 4, "name": "Cleanroom Conveyors", "item": "https://packagingconveyor.com/industries/pharmaceutical-conveyors/cleanroom/" }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a cleanroom conveyor?",
      "acceptedAnswer": { "@type": "Answer", "text": "A cleanroom conveyor is a material handling system designed to operate within ISO 14644-1 classified environments (ISO Class 5 through Class 8) without generating particles that would compromise the cleanroom classification. Cleanroom conveyors use smooth, non-shedding surfaces (electropolished stainless steel, anodized aluminum), sealed bearings, enclosed drives, and materials that do not outgas volatile organic compounds. They serve pharmaceutical, medical device, semiconductor, and optics manufacturing." }
    },
    {
      "@type": "Question",
      "name": "What ISO cleanroom classes require specialized conveyors?",
      "acceptedAnswer": { "@type": "Answer", "text": "ISO Class 7 and Class 8 environments can use standard stainless steel conveyors with sealed bearings and smooth finishes. ISO Class 6 requires enclosed drives, particle-tested belts, and certified low-particle generation. ISO Class 5 (equivalent to the old Federal Standard 209E Class 100) requires fully enclosed conveyor systems, HEPA-filtered enclosures, and rigorous material qualification to prevent particle generation above 0.5 microns." }
    },
    {
      "@type": "Question",
      "name": "What conveyor belt materials are cleanroom compatible?",
      "acceptedAnswer": { "@type": "Answer", "text": "Cleanroom-compatible belt materials include silicone-free polyurethane, PTFE-coated fiberglass, and monofilament polyester mesh. These materials generate minimal particles during operation, do not outgas volatile compounds, and resist the cleaning chemicals used in cleanroom environments (IPA, hydrogen peroxide, quaternary ammonium). Standard PVC and rubber belts are generally not cleanroom-compatible due to plasticizer outgassing and particle shedding." }
    },
    {
      "@type": "Question",
      "name": "How do you validate a cleanroom conveyor?",
      "acceptedAnswer": { "@type": "Answer", "text": "Cleanroom conveyor validation includes particle generation testing (running the conveyor and measuring airborne particles at the belt surface), outgassing testing (measuring VOC emissions from belt and component materials), surface finish verification (Ra values on metal surfaces), and operational qualification under production conditions. Validation follows the facility's cleanroom qualification protocol and must demonstrate the conveyor does not cause the room to exceed its ISO classification during operation." }
    }
  ]
};

const articleSchema = {
