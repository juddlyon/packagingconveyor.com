const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What conveyors are used in a packaging line?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A complete packaging line uses belt conveyors between filling and capping stations, accumulation conveyors between machines that run at different speeds, transfer conveyors for right-angle turns, roller conveyors for case transport, and pallet conveyors for finished goods. Most lines also include reject conveyors for QC diversions, laning conveyors to split single-file product into multiple lanes, and indexing conveyors for precise positioning at labelers or robotic pick points."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between primary, secondary, and tertiary packaging conveyors?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Primary packaging conveyors handle individual products during filling, sealing, and labeling. They require gentle handling and precise positioning. Secondary packaging conveyors transport cases, cartons, bundles, and trays through case packing, case sealing, and shrink wrapping. They handle heavier loads at higher speeds. Tertiary packaging conveyors move palletized loads to stretch wrappers, staging, and shipping docks. They carry the heaviest loads (up to 4,000+ lbs) at the slowest speeds."
      }
    },
    {
      "@type": "Question",
      "name": "How much accumulation do I need between packaging machines?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The standard rule of thumb is 3-5 minutes of accumulation between each pair of machines. This buffer absorbs minor stoppages (jam clearing, roll changes, label changes) without stopping upstream or downstream equipment. Calculate the length needed: Minutes of buffer x Products per minute x Product pitch (length + gap) = Total accumulation length required. For critical buffers between high-speed fillers and case packers, 5-10 minutes may be needed."
      }
    },
    {
      "@type": "Question",
      "name": "What conveyor speed do I need for my packaging line?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Conveyor speed depends on throughput: Speed (FPM) = (Products per minute x Product pitch in feet). Product pitch = product length + gap between products. Always add 10-15% speed headroom above peak throughput. Common ranges: bottle/can lines 20-100 FPM, case conveyors 50-200 FPM, pallet conveyors 20-60 FPM. The conveyor must match or slightly exceed the speed of the fastest machine it feeds."
      }
    }
  ]
};

