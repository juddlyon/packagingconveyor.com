                <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4 pr-4">Open Area</th>
                <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4 pr-4">Temp Rating</th>
                <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4 pr-4">Best For</th>
                <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4">Cost</th>
              </tr>
            </thead>
            <tbody class="text-base text-ink-muted">
              <tr class="border-b border-border">
                <td class="py-4 pr-4 font-semibold text-ink">Balanced weave</td>
                <td class="py-4 pr-4 font-mono text-sm">30-50%</td>
                <td class="py-4 pr-4 font-mono text-sm">-40 to 1800 F</td>
                <td class="py-4 pr-4">General cooling, baking</td>
                <td class="py-4 font-mono text-sm">$$</td>
              </tr>
              <tr class="border-b border-border">
