---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy | PackagingConveyor.com"
  description="Privacy policy for PackagingConveyor.com. We collect no personal data. No tracking, no analytics, no cookies beyond standard hosting."
  canonical="https://packagingconveyor.com/privacy/"
>

  <!-- Hero -->
  <section class="py-24 bg-surface-dim bg-dots">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-label text-accent mb-4">Legal</div>
      <h1 class="font-display text-5xl sm:text-6xl font-800 text-ink tracking-wide uppercase leading-tight mb-6">
        Privacy Policy
      </h1>
      <p class="text-xl text-ink-muted leading-relaxed max-w-2xl">
        Effective date: March 2026
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-24 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">

      <!-- What we collect -->
      <div>
        <h2 class="font-display text-3xl font-800 text-ink tracking-wide mb-6">
          What Data We Collect
        </h2>
        <div class="text-lg text-ink-muted leading-relaxed space-y-4">
          <p>
            <strong class="text-ink">Essentially nothing.</strong> PackagingConveyor.com has no user accounts, no contact forms, no comment system, and no newsletter signup. There is no mechanism on this site to collect your personal information.
          </p>
          <p>
            We do not use Google Analytics, Facebook Pixel, or any other third-party tracking or analytics service. We do not track your behavior across pages or sessions.
          </p>
        </div>
      </div>

      <!-- Hosting -->
      <div>
        <h2 class="font-display text-3xl font-800 text-ink tracking-wide mb-6">
          Hosting: Netlify
        </h2>
        <div class="text-lg text-ink-muted leading-relaxed space-y-4">
          <p>
            This site is hosted on <strong class="text-ink">Netlify</strong>. Like any web host, Netlify's servers receive standard HTTP request data when you visit a page , your IP address, browser type, referring URL, and pages requested. This is logged at the infrastructure level for security and performance purposes.
          </p>
          <p>
            We do not access or process these server logs for advertising or profiling. You can review Netlify's privacy policy at <a href="https://www.netlify.com/privacy/" class="text-accent font-semibold hover:text-accent-hover" target="_blank" rel="noopener">netlify.com/privacy</a>.
          </p>
        </div>
      </div>

      <!-- Cookies -->
      <div>
        <h2 class="font-display text-3xl font-800 text-ink tracking-wide mb-6">
          Cookies
        </h2>
        <div class="text-lg text-ink-muted leading-relaxed space-y-4">
          <p>
            We do not set any first-party cookies. Netlify may set functional cookies as part of their CDN and edge network operations. We do not use cookies for advertising, retargeting, or analytics.
          </p>
        </div>
      </div>

      <!-- Future changes -->
      <div>
        <h2 class="font-display text-3xl font-800 text-ink tracking-wide mb-6">
          Future Changes
        </h2>
        <div class="text-lg text-ink-muted leading-relaxed space-y-4">
          <p>
            If we add contact forms, analytics, or any other feature that involves data collection, this policy will be updated before that feature goes live. The effective date at the top of this page will reflect the most recent revision.
          </p>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h2 class="font-display text-3xl font-800 text-ink tracking-wide mb-6">
          Questions
        </h2>
        <div class="text-lg text-ink-muted leading-relaxed space-y-4">
          <p>
            If you have questions about this privacy policy, contact us at <a href="mailto:info@packagingconveyor.com" class="text-accent font-semibold hover:text-accent-hover">info@packagingconveyor.com</a>.
          </p>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
