---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms of Use | PackagingConveyor.com"
  description="Terms of use for PackagingConveyor.com. Content is for informational purposes only and is not a substitute for professional engineering advice."
  canonical="https://packagingconveyor.com/terms/"
>

  <!-- Hero -->
  <section class="py-24 bg-surface-dim bg-dots">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-label text-accent mb-4">Legal</div>
      <h1 class="font-display text-5xl sm:text-6xl font-800 text-ink tracking-wide uppercase leading-tight mb-6">
        Terms of Use
      </h1>
      <p class="text-xl text-ink-muted leading-relaxed max-w-2xl">
        By using this site, you agree to the following terms.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-24 bg-surface">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 space-y-16">

      <!-- Informational only -->
      <div>
        <h2 class="font-display text-3xl font-800 text-ink tracking-wide mb-6">
          Informational Purposes Only
        </h2>
        <div class="text-lg text-ink-muted leading-relaxed space-y-4">
          <p>
            All content on PackagingConveyor.com — guides, specifications, pricing ranges, selection criteria, and comparisons — is provided for <strong class="text-ink">informational and educational purposes only</strong>.
          </p>
          <p>
            This site is not a substitute for professional engineering advice. Conveyor system design involves site-specific load calculations, safety assessments, regulatory compliance requirements, and application variables that cannot be addressed by a general reference guide. Consult a qualified engineer or conveyor systems integrator before making purchasing or design decisions.
          </p>
        </div>
      </div>

      <!-- Pricing accuracy -->
      <div>
        <h2 class="font-display text-3xl font-800 text-ink tracking-wide mb-6">
          Pricing Information
        </h2>
        <div class="text-lg text-ink-muted leading-relaxed space-y-4">
          <p>
            Pricing ranges published on this site are approximate and are intended as budgeting reference only. Actual prices vary based on manufacturer, configuration, options, lead time, quantity, and current market conditions — including material costs and supply chain factors.
          </p>
          <p>
            Do not use prices from this site as the basis for formal budgets, bids, or contracts without obtaining current quotes from qualified vendors.
          </p>
        </div>
      </div>

      <!-- No warranties -->
      <div>
        <h2 class="font-display text-3xl font-800 text-ink tracking-wide mb-6">
          No Warranties
        </h2>
        <div class="text-lg text-ink-muted leading-relaxed space-y-4">
          <p>
            We make reasonable efforts to ensure the accuracy of information on this site, but we make <strong class="text-ink">no warranties — express or implied — about its completeness, accuracy, or fitness for any particular purpose</strong>. Technical specifications, standards, and pricing change over time. Verify current specifications with the relevant manufacturer or standards body before acting on any data from this site.
          </p>
          <p>
            This site is provided "as is." Use it at your own discretion and risk.
          </p>
        </div>
      </div>

      <!-- Limitation of liability -->
      <div>
        <h2 class="font-display text-3xl font-800 text-ink tracking-wide mb-6">
          Limitation of Liability
        </h2>
        <div class="text-lg text-ink-muted leading-relaxed space-y-4">
          <p>
            PackagingConveyor.com and its operators are not liable for any direct, indirect, incidental, or consequential damages arising from your use of this site or reliance on its content. This includes — but is not limited to — purchasing decisions, project cost overruns, equipment mismatches, or design errors that result from information found here.
          </p>
          <p>
            The responsibility for any procurement or engineering decision rests with the buyer and their qualified advisors.
          </p>
        </div>
      </div>

      <!-- Intellectual property -->
      <div>
        <h2 class="font-display text-3xl font-800 text-ink tracking-wide mb-6">
          Content and Intellectual Property
        </h2>
        <div class="text-lg text-ink-muted leading-relaxed space-y-4">
          <p>
            The editorial content, guides, and structure of this site are the property of PackagingConveyor.com. You may reference and link to our content freely. You may not republish, scrape, or reproduce substantial portions of our content without permission.
          </p>
        </div>
      </div>

      <!-- Changes to terms -->
      <div>
        <h2 class="font-display text-3xl font-800 text-ink tracking-wide mb-6">
          Changes to These Terms
        </h2>
        <div class="text-lg text-ink-muted leading-relaxed space-y-4">
          <p>
            We may update these terms as the site evolves. Continued use of the site constitutes acceptance of the current terms. Check this page periodically if you rely on this site regularly.
          </p>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h2 class="font-display text-3xl font-800 text-ink tracking-wide mb-6">
          Contact
        </h2>
        <div class="text-lg text-ink-muted leading-relaxed space-y-4">
          <p>
            For questions about these terms, contact us at <a href="mailto:info@packagingconveyor.com" class="text-accent font-semibold hover:text-accent-hover">info@packagingconveyor.com</a>.
          </p>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
