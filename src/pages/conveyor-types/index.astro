const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://packagingconveyor.com/" },
    { "@type": "ListItem", "position": 2, "name": "Conveyor Types", "item": "https://packagingconveyor.com/conveyor-types/" }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How many types of conveyors are there?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The packaging industry uses over 30 distinct conveyor types. The major categories include roller conveyors (gravity, powered, MDR, CDLR), belt conveyors (flat, cleated, modular), chain conveyors (tabletop, drag, slat), accumulation conveyors, transfer conveyors, spiral conveyors, sortation systems, vertical reciprocating conveyors, overhead conveyors, and specialty types like vibratory, magnetic, and vacuum conveyors."
      }
    },
    {
      "@type": "Question",
      "name": "What is the most common conveyor type in packaging?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Belt conveyors and roller conveyors are the two most common conveyor types in packaging operations. Belt conveyors handle lightweight and irregular products. Roller conveyors (gravity and powered) dominate case and carton transport. MDR roller conveyors have become the standard for zone-controlled accumulation in distribution and fulfillment centers."
      }
    },
    {
      "@type": "Question",
      "name": "How do I choose the right conveyor type?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Conveyor selection depends on five key factors: product characteristics (weight, size, shape, bottom surface), throughput requirement (units per minute), function needed (transport, accumulate, sort, elevate), environment (food-grade, washdown, cleanroom, temperature), and budget. Start by defining these requirements, then match them against conveyor type capabilities."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between a belt conveyor and a roller conveyor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Belt conveyors use a continuous belt surface and can carry products of any shape, size, or bottom condition. Roller conveyors use a series of cylindrical rollers and require products with a flat, rigid bottom at least 3 rollers wide. Belt conveyors handle inclines and declines better. Roller conveyors offer easier zone control, accumulation, and lower friction for heavy loads."
      }
    },
    {
      "@type": "Question",
      "name": "What conveyor types support zero-pressure accumulation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Three conveyor types commonly provide zero-pressure accumulation (ZPA): MDR (Motor Driven Roller) conveyors use independent 24VDC motorized zones. Belt-driven live roller conveyors use pneumatic clutches or band brakes per zone. Accumulation conveyors with photo-eye sensors and zone controllers manage product spacing. MDR is the most widely specified ZPA technology for new installations."
      }
    }
  ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Types of Conveyors: Complete Guide to Packaging Conveyor Systems",
  "description": "Comprehensive guide to 30+ packaging conveyor types including roller, belt, chain, accumulation, transfer, MDR, CDLR, spiral, and sortation conveyors with specifications and selection criteria.",
  "url": "https://packagingconveyor.com/conveyor-types/",
  "publisher": {
    "@type": "Organization",
    "name": "PackagingConveyor.com",
    "url": "https://packagingconveyor.com"
  }
};
---

<BaseLayout title="Types of Conveyors: Complete Guide to 30+ Packaging Conveyor Systems" description="Comprehensive guide to 30+ types of conveyors used in packaging. Roller, belt, chain, MDR, CDLR, accumulation, transfer, spiral &#x26; more with specs and selection criteria." canonical="https://packagingconveyor.com/conveyor-types/" schema={[breadcrumbSchema, faqSchema, articleSchema]}>

  <!-- Breadcrumb -->
  <nav class="bg-surface border-b border-border" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-ink-muted">
        <li><a href="/" class="hover:text-accent transition-colors">Home</a></li>
        <li class="text-ink-muted/50">/</li>
        <li class="text-ink font-semibold">Conveyor Types</li>
      </ol>
    </div>
  </nav>

  <!-- AIO Definition -->
  <section class="py-16 sm:py-20 bg-surface-dim bg-dots">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-label text-accent mb-4">Conveyor Types</div>
      <h1 class="font-display text-5xl sm:text-6xl font-extrabold text-ink tracking-wide uppercase leading-tight mb-8">
        Types of Conveyors: Complete Guide to Packaging Conveyor Systems
      </h1>
      <div class="text-xl text-ink-muted leading-relaxed max-w-3xl">
        <p>Packaging operations use over 30 distinct conveyor types to transport, accumulate, sort, and elevate products between processes. The major categories include roller conveyors, belt conveyors, chain conveyors, accumulation conveyors, transfer conveyors, vertical conveyors, and sortation systems. Each type serves a specific function based on product weight, shape, speed requirements, and environment.</p>
      </div>
    </div>
  </section>

  <!-- All Types Grid -->
  <section class="py-20 bg-surface" aria-labelledby="all-types-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-label text-accent mb-4">Browse All Types</div>
      <h2 id="all-types-heading" class="font-display text-4xl sm:text-5xl font-extrabold text-ink tracking-wide mb-6">
        30+ Conveyor Types for <span class="text-accent">Packaging</span>
      </h2>
      <p class="text-lg text-ink-muted leading-relaxed max-w-3xl mb-12">
        Select a conveyor type below for detailed specifications, selection criteria, manufacturer references, and comparison data. Pages marked with a tag list indicate key sub-types covered.
      </p>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {conveyorTypes.map((type) => (
          <a href="{type.slug}" class="card group p-6 flex flex-col">
            <h3 class="font-display text-xl font-bold uppercase tracking-wider text-ink group-hover:text-accent transition-colors mb-2">{type.name}</h3>
            <p class="text-base text-ink-muted leading-relaxed mb-4 flex-1">{type.desc}</p>
            <div class="flex flex-wrap gap-2">
              {type.tags.map((tag: string) => (
                <span class="text-xs font-semibold px-2.5 py-1 bg-ink/5 text-ink-muted">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Selection Guide -->
  <section class="py-20 bg-surface-dim bg-dots" aria-labelledby="selection-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-label text-accent mb-4">Selection Guide</div>
      <h2 id="selection-heading" class="font-display text-4xl sm:text-5xl font-extrabold text-ink tracking-wide mb-8">
        How to Choose the Right <span class="text-accent">Conveyor Type</span>
      </h2>
      <div class="text-lg text-ink-muted leading-relaxed space-y-6">
        <p>Conveyor selection starts with five fundamental parameters. Define these before evaluating any equipment.</p>

        <h3 class="font-display text-2xl font-bold uppercase tracking-wider text-ink">1. Product Characteristics</h3>
        <p>Product weight, dimensions, shape, bottom surface condition, and fragility determine which conveyor types qualify. Flat-bottomed rigid cases suit <a href="/conveyor-types/roller-conveyors/" class="text-accent hover:text-accent-hover font-semibold">roller conveyors</a>. Irregular shapes or soft-bottom bags require belt conveyors. Heavy pallets need <a href="/conveyor-types/cdlr-conveyors/" class="text-accent hover:text-accent-hover font-semibold">CDLR conveyors</a> or pallet chain conveyors.</p>

        <h3 class="font-display text-2xl font-bold uppercase tracking-wider text-ink">2. Throughput Requirements</h3>
        <p>Calculate your required conveyor speed using this formula: Speed (FPM) = (products per minute x product length in feet) + gap allowance. Add 10-15% headroom above peak production rate. Higher throughput applications may require <a href="/conveyor-types/live-roller-conveyors/" class="text-accent hover:text-accent-hover font-semibold">live roller conveyors</a> or high-speed belt systems.</p>

        <h3 class="font-display text-2xl font-bold uppercase tracking-wider text-ink">3. Function Needed</h3>
        <p>Transport is the baseline function. Beyond transport, you may need <a href="/conveyor-types/accumulation-conveyors/" class="text-accent hover:text-accent-hover font-semibold">accumulation</a> (buffering between processes), <a href="/conveyor-types/transfer-conveyors/" class="text-accent hover:text-accent-hover font-semibold">transfer</a> (direction changes), sortation (routing to multiple destinations), or <a href="/conveyor-types/vertical-reciprocating/" class="text-accent hover:text-accent-hover font-semibold">vertical transport</a> (elevation changes).</p>

        <h3 class="font-display text-2xl font-bold uppercase tracking-wider text-ink">4. Environment</h3>
        <p><a href="/industries/food-conveyors/" class="text-accent hover:text-accent-hover font-semibold">Food and beverage operations</a> require <a href="/industries/food-conveyors/sanitary/" class="text-accent hover:text-accent-hover font-semibold">sanitary, washdown-rated conveyors</a> in stainless steel. Pharmaceutical plants need cleanroom-compatible systems. Standard warehouse environments can use painted carbon steel frames.</p>

        <h3 class="font-display text-2xl font-bold uppercase tracking-wider text-ink">5. Budget</h3>
        <p>Conveyor cost varies dramatically by type. <a href="/conveyor-types/roller-conveyors/gravity/" class="text-accent hover:text-accent-hover font-semibold">Gravity roller conveyors</a> represent the lowest cost option ($). <a href="/conveyor-types/mdr-conveyors/" class="text-accent hover:text-accent-hover font-semibold">MDR conveyors</a> cost more upfront ($$$) but reduce energy and maintenance costs over time. See our <a href="/resources/conveyor-cost-guide/" class="text-accent hover:text-accent-hover font-semibold">conveyor cost guide</a> for detailed cost factor breakdowns.</p>
      </div>
    </div>
  </section>

  <!-- Quick Comparison Table -->
  <section class="py-20 bg-surface" aria-labelledby="comparison-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-label text-accent mb-4">Quick Reference</div>
      <h2 id="comparison-heading" class="font-display text-4xl sm:text-5xl font-extrabold text-ink tracking-wide mb-10">
        Conveyor Type <span class="text-accent">Comparison Table</span>
      </h2>

      <div class="overflow-x-auto -mx-4 px-4">
        <table class="w-full text-left border-collapse min-w-[800px]">
          <thead>
            <tr class="border-b-2 border-ink">
              <th class="font-display text-sm font-bold uppercase tracking-wider text-ink py-4 pr-4">Type</th>
              <th class="font-display text-sm font-bold uppercase tracking-wider text-ink py-4 pr-4">Best For</th>
              <th class="font-display text-sm font-bold uppercase tracking-wider text-ink py-4 pr-4">Speed</th>
              <th class="font-display text-sm font-bold uppercase tracking-wider text-ink py-4 pr-4">Load</th>
              <th class="font-display text-sm font-bold uppercase tracking-wider text-ink py-4 pr-4">Accumulation</th>
              <th class="font-display text-sm font-bold uppercase tracking-wider text-ink py-4">Cost</th>
            </tr>
          </thead>
          <tbody class="text-base text-ink-muted">
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink"><a href="/conveyor-types/roller-conveyors/gravity/" class="text-accent hover:text-accent-hover">Gravity Roller</a></td>
              <td class="py-3 pr-4">Cases, cartons, totes</td>
              <td class="py-3 pr-4 font-mono text-sm">Gravity</td>
              <td class="py-3 pr-4 font-mono text-sm">Up to 200 lbs</td>
              <td class="py-3 pr-4">No</td>
              <td class="py-3 font-mono text-sm">$</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink"><a href="/conveyor-types/roller-conveyors/powered/" class="text-accent hover:text-accent-hover">Powered Roller</a></td>
              <td class="py-3 pr-4">Continuous case flow</td>
              <td class="py-3 pr-4 font-mono text-sm">30-200 FPM</td>
              <td class="py-3 pr-4 font-mono text-sm">Up to 500 lbs</td>
              <td class="py-3 pr-4">With add-ons</td>
              <td class="py-3 font-mono text-sm">$$</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink"><a href="/conveyor-types/mdr-conveyors/" class="text-accent hover:text-accent-hover">MDR</a></td>
              <td class="py-3 pr-4">Zone accumulation</td>
              <td class="py-3 pr-4 font-mono text-sm">30-180 FPM</td>
              <td class="py-3 pr-4 font-mono text-sm">Up to 250 lbs</td>
              <td class="py-3 pr-4">Built-in ZPA</td>
              <td class="py-3 font-mono text-sm">$$$</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink"><a href="/conveyor-types/cdlr-conveyors/" class="text-accent hover:text-accent-hover">CDLR</a></td>
              <td class="py-3 pr-4">Heavy pallets, cases</td>
              <td class="py-3 pr-4 font-mono text-sm">20-120 FPM</td>
              <td class="py-3 pr-4 font-mono text-sm">Up to 10,000 lbs</td>
              <td class="py-3 pr-4">No (continuous)</td>
              <td class="py-3 font-mono text-sm">$$$</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink"><a href="/conveyor-types/live-roller-conveyors/" class="text-accent hover:text-accent-hover">Live Roller (BDLR)</a></td>
