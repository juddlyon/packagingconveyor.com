              <td class="py-3 pr-4">With zones</td>
              <td class="py-3 font-mono text-sm">$$</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink"><a href="/conveyor-types/accumulation-conveyors/" class="text-accent hover:text-accent-hover">Accumulation</a></td>
              <td class="py-3 pr-4">Line buffering</td>
              <td class="py-3 pr-4 font-mono text-sm">30-180 FPM</td>
              <td class="py-3 pr-4 font-mono text-sm">Up to 300 lbs</td>
              <td class="py-3 pr-4">Primary function</td>
              <td class="py-3 font-mono text-sm">$$$</td>
            </tr>
            <tr class="border-b border-border">
