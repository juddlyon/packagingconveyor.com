      <h2 id="related-heading" class="font-display text-3xl font-extrabold text-white tracking-wide mb-8">Continue <span class="text-accent-bright">Researching</span></h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/conveyor-types/roller-conveyors/" class="p-5 border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-accent/40 transition-all group">
          <div class="font-display text-lg font-bold uppercase tracking-wider text-white group-hover:text-accent-bright transition-colors mb-1">Roller Conveyors</div>
          <p class="text-sm text-white/60">All roller types compared</p>
        </a>
        <a href="/conveyor-types/mdr-conveyors/" class="p-5 border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-accent/40 transition-all group">
          <div class="font-display text-lg font-bold uppercase tracking-wider text-white group-hover:text-accent-bright transition-colors mb-1">MDR Conveyors</div>
