              <td class="py-3 pr-4 font-semibold text-ink">Chain Size</td>
              <td class="py-3 pr-4 font-mono text-sm">ANSI #40-#50</td>
              <td class="py-3 font-mono text-sm">ANSI #50-#60</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">Frame Width (BF)</td>
              <td class="py-3 pr-4 font-mono text-sm">18"-36"</td>
              <td class="py-3 font-mono text-sm">36"-60"</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">Noise Level</td>
              <td class="py-3 pr-4 font-mono text-sm">70-80 dB</td>
