              <td class="py-3 pr-4 font-mono text-sm">>99.5%</td>
              <td class="py-3 font-mono text-sm">>99.5%</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">Destinations</td>
              <td class="py-3 pr-4 font-mono text-sm">20-200</td>
              <td class="py-3 pr-4 font-mono text-sm">10-50</td>
              <td class="py-3 pr-4 font-mono text-sm">50-500+</td>
              <td class="py-3 pr-4 font-mono text-sm">30-200</td>
              <td class="py-3 font-mono text-sm">30-200</td>
            </tr>
            <tr>
              <td class="py-3 pr-4 font-semibold text-ink">Relative Cost</td>
              <td class="py-3 pr-4 font-mono text-sm">$$$</td>
              <td class="py-3 pr-4 font-mono text-sm">$$</td>
              <td class="py-3 pr-4 font-mono text-sm">$$$$</td>
              <td class="py-3 pr-4 font-mono text-sm">$$$</td>
