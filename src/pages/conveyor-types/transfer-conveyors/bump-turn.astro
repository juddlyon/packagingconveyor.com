    { "@type": "ListItem", "position": 4, "name": "Bump Turn Conveyors", "item": "https://packagingconveyor.com/conveyor-types/transfer-conveyors/bump-turn/" }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a bump turn conveyor?",
      "acceptedAnswer": { "@type": "Answer", "text": "A bump turn conveyor uses angled rollers, skate wheels, or guide rails at a conveyor junction to redirect products around a curve — typically 30, 45, or 90 degrees — without a powered transfer mechanism. The product's forward momentum carries it into the angled surface, which 'bumps' (deflects) it onto the new path. Passive bump turns use no motors at the turn point, relying on gravity and inertia. Powered bump turns add driven rollers to maintain speed through the turn." }
    },
    {
      "@type": "Question",
      "name": "What is the difference between a passive and powered bump turn?",
      "acceptedAnswer": { "@type": "Answer", "text": "A passive bump turn uses angled dead rollers or skate wheels and relies entirely on the product's incoming momentum to carry it through the turn. A powered bump turn adds motorized tapered rollers or angled driven rollers that actively propel the product through the curve. Passive turns cost less but require higher infeed speeds and can stall heavy products. Powered turns handle heavier loads and maintain consistent speed regardless of product weight." }
    },
    {
      "@type": "Question",
      "name": "Does a bump turn change product orientation?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, bump turns rotate the product's orientation relative to the conveyor line. A 90-degree bump turn rotates the product 90 degrees — the leading edge becomes a side edge. This orientation change can be intentional (rotating cases for labeling or palletizing) or undesirable (misaligning barcodes for scanning). If orientation must be maintained through a direction change, use a pop-up transfer or turntable instead." }
    }
