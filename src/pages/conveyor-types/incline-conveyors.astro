<BaseLayout title="Incline Conveyors: Elevation Change with Belt, Cleated &#x26; Z-Frame Systems" description="Complete guide to incline conveyors: incline angles, cleated belts, Z-frame designs, decline operation, noseover transfers, and product grip for packaging lines." canonical="https://packagingconveyor.com/conveyor-types/incline-conveyors/" schema={[breadcrumbSchema, faqSchema, articleSchema]}>

  <!-- Breadcrumb -->
  <nav class="bg-surface border-b border-border" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-ink-muted">
