const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are the different types of roller conveyors?",
      "acceptedAnswer": { "@type": "Answer", "text": "The four main types of roller conveyors are gravity roller (unpowered, product moves by gravity or manual push), powered roller or belt-driven live roller (BDLR, single motor drives all rollers via belt), line-shaft roller (single motor drives all rollers via splined shaft and O-ring bands), and motor driven roller (MDR, individual 24VDC motors inside rollers for zone control). Chain driven live roller (CDLR) is a fifth type used for heavy-duty pallet handling." }
    },
    {
      "@type": "Question",
      "name": "How do I choose between gravity and powered roller conveyors?",
      "acceptedAnswer": { "@type": "Answer", "text": "Choose gravity roller when you have a slight decline available (3-5 degrees), product weights are consistent, and you do not need controlled speed or accumulation. Choose powered roller when you need consistent speed regardless of load, uphill transport, controlled accumulation, or integration with automated systems. Gravity roller costs significantly less than powered roller per linear foot." }
    },
    {
      "@type": "Question",
      "name": "What is the weight capacity of a roller conveyor?",
      "acceptedAnswer": { "@type": "Answer", "text": "Roller conveyor weight capacity depends on the type. Standard gravity rollers handle up to 75-200 lbs per product. Belt-driven live roller (BDLR) handles up to 500 lbs. MDR conveyors typically handle up to 150-250 lbs per zone. CDLR conveyors handle 500-10,000+ lbs for heavy pallet applications. Capacity depends on roller diameter, wall thickness, bearing type, axle size, and frame gauge." }
    },
    {
      "@type": "Question",
      "name": "What roller spacing do I need?",
      "acceptedAnswer": { "@type": "Answer", "text": "The standard rule is that at least 3 rollers must contact the product bottom at all times. Divide your smallest product length by 3, then round down to the nearest standard pitch. Common roller spacings are 1.5 inches, 2 inches, 3 inches, 4.5 inches, and 6 inches. For example, a 12-inch case needs 4-inch or smaller roller spacing (12 / 3 = 4)." }
    },
    {
      "@type": "Question",
      "name": "What is MDR and why is it replacing line-shaft conveyors?",
      "acceptedAnswer": { "@type": "Answer", "text": "MDR (Motor Driven Roller) uses small brushless DC motors built inside individual conveyor rollers, controlled in independent zones. MDR is replacing line-shaft and belt-driven live roller because it provides zero-pressure accumulation without pneumatics, uses 50%+ less energy, runs quieter (65 dB vs 80+ dB), requires less maintenance (no belts, chains, or O-rings to replace), and supports easy zone-by-zone expansion. Interroll, Itoh Denki, and Rulmeca are leading MDR roller manufacturers." }
    }
  ]
};

