    { "@type": "ListItem", "position": 3, "name": "Pneumatic Conveyor Systems", "item": "https://packagingconveyor.com/conveyor-types/pneumatic-conveyors/" }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a pneumatic conveyor?",
      "acceptedAnswer": { "@type": "Answer", "text": "A pneumatic conveyor uses air pressure or vacuum to transport dry bulk materials through enclosed pipelines. Materials like powders, granules, pellets, and flakes suspend in the airstream (dilute phase) or move as a dense plug (dense phase) through sealed tubes from source to destination. Pneumatic conveyors eliminate open material exposure, contain dust, navigate complex routing with bends and elevation changes, and transport materials over distances from 50 feet to over 1,000 feet." }
    },
    {
      "@type": "Question",
      "name": "What is the difference between dilute phase and dense phase pneumatic conveying?",
      "acceptedAnswer": { "@type": "Answer", "text": "Dilute phase conveying suspends material in a high-velocity airstream (3,500-5,000+ FPM) at low material-to-air ratios. Dense phase conveying pushes material as slugs or plugs through the pipeline at lower velocities (500-1,500 FPM) and higher pressures. Dilute phase suits non-abrasive, non-fragile materials and costs less to install. Dense phase suits fragile, abrasive, or high-value materials because lower velocity reduces particle breakage and pipe wear." }
    },
    {
      "@type": "Question",
      "name": "What materials can be pneumatically conveyed?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pneumatic conveyors handle most dry bulk solids: powders (flour, cement, starch, pigments), granules (sugar, salt, resin pellets, coffee), pellets (plastic resin, pet food, animal feed), flakes (cereal, dried herbs), and fibers (wood dust, textile waste). Materials that are very wet, sticky, hygroscopic, or have extremely high bulk density may not convey pneumatically without special system modifications." }
    },
    {
      "@type": "Question",
      "name": "Pneumatic conveyor vs. mechanical conveyor: which is better?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pneumatic conveyors excel at enclosed dust-free transport, complex routing through walls and floors, multiple pickup and delivery points, and handling hazardous or contamination-sensitive materials. Mechanical conveyors (belt, screw, drag chain) use less energy per ton, handle higher capacities, and cost less for short straight-line runs. Pneumatic systems consume 3-10 times more energy than mechanical conveyors for the same throughput, but they eliminate spillage, contamination, and dust exposure." }
    }
  ]
