const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a belt conveyor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A belt conveyor uses a continuous loop of material (the belt) stretched between two or more pulleys to transport products. The belt wraps around a head pulley (driven) and a tail pulley (idler), with the top surface carrying products and the bottom returning empty. Belt conveyors handle products of any shape, size, or bottom condition, including bags, pouches, irregular shapes, and loose items that roller conveyors cannot transport."
      }
    },
    {
      "@type": "Question",
      "name": "What are the different types of conveyor belts?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Common conveyor belt types include: flat belt (smooth surface for general transport), cleated belt (raised flights for inclines and product separation), modular plastic belt (interlocking modules for food and washdown), timing/positive drive belt (toothed for precise positioning), wire mesh belt (open weave for high temperatures), and specialty belts (vacuum, magnetic, rough-top). Each type suits different products, environments, and application requirements."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between a belt conveyor and a roller conveyor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Belt conveyors use a continuous belt surface and can transport products of any shape or bottom condition. Roller conveyors use cylindrical rollers and require flat, rigid product bottoms spanning at least 3 rollers. Belt conveyors excel at inclines, handling bags and pouches, and transporting small or loose items. Roller conveyors offer easier zone control, accumulation, and lower friction for heavy flat-bottomed loads like cases and pallets."
      }
    },
    {
      "@type": "Question",
      "name": "What belt conveyor is best for food applications?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Modular plastic belt conveyors are the preferred choice for food and beverage applications because they are easy to clean (individual modules can be removed), resistant to water and chemicals, available in FDA-compliant materials, and suitable for washdown environments. For dry food applications, FDA-compliant PU (polyurethane) flat belts are also common. Wire mesh belts are used for baking, cooling, and freezing applications."
      }
    },
    {
      "@type": "Question",
      "name": "How fast can a belt conveyor run?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Belt conveyor speeds typically range from 20 to 400 feet per minute (FPM) depending on the application. Light-duty packaging conveyors commonly run at 50-150 FPM. High-speed sortation and distribution conveyors may reach 400-600 FPM. Maximum practical speed depends on belt type, product stability, and the ability to load and unload products at the conveyor ends. Incline conveyors run slower to prevent product slippage."
      }
