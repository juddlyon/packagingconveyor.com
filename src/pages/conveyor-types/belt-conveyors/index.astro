        Explore Belt Conveyor <span class="text-accent">Sub-Types</span>
      </h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {beltTypes.map((type) => (
          <a href="{type.slug}" class="card group p-6">
