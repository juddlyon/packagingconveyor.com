            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">Product Flow</td>
              <td class="py-3 pr-4">Batch (reciprocating)</td>
              <td class="py-3 pr-4">Batch (reciprocating)</td>
              <td class="py-3">Continuous</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">Throughput</td>
              <td class="py-3 pr-4">10-20 loads/hr typical</td>
              <td class="py-3 pr-4">10-15 loads/hr typical</td>
              <td class="py-3">Continuous (matched to line)</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">Max Height</td>
              <td class="py-3 pr-4 font-mono text-sm">Up to 100+ ft</td>
              <td class="py-3 pr-4 font-mono text-sm">Unlimited</td>
              <td class="py-3 font-mono text-sm">Up to 40 ft</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">Pit Required?</td>
              <td class="py-3 pr-4">No (surface mount)</td>
              <td class="py-3 pr-4">Yes (code required)</td>
              <td class="py-3">No</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">Machine Room?</td>
              <td class="py-3 pr-4">No</td>
              <td class="py-3 pr-4">Yes (code required)</td>
              <td class="py-3">No</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">Installation Time</td>
              <td class="py-3 pr-4">1-3 weeks</td>
              <td class="py-3 pr-4">2-6 months</td>
              <td class="py-3">2-4 weeks</td>
            </tr>
            <tr>
              <td class="py-3 pr-4 font-semibold text-ink">Relative Cost</td>
              <td class="py-3 pr-4 font-mono text-sm">$$$</td>
              <td class="py-3 pr-4 font-mono text-sm">$$$$</td>
              <td class="py-3 font-mono text-sm">$$$$</td>
