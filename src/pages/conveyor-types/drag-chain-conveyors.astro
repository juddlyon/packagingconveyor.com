              <td class="py-3 pr-4">Moderate</td>
              <td class="py-3 pr-4">Highest</td>
              <td class="py-3">Low</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">3D Routing</td>
              <td class="py-3 pr-4">Limited curves</td>
              <td class="py-3 pr-4">Full 3D paths</td>
              <td class="py-3">Moderate</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">Dust Containment</td>
              <td class="py-3 pr-4">Enclosed trough</td>
              <td class="py-3 pr-4">Sealed tube (best)</td>
              <td class="py-3">Sealed tube</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">Best Materials</td>
              <td class="py-3 pr-4">Grain, cement, powder</td>
              <td class="py-3 pr-4">Fragile food, pharma</td>
              <td class="py-3">Wet, sticky materials</td>
            </tr>
            <tr>
              <td class="py-3 pr-4 font-semibold text-ink">Relative Cost</td>
              <td class="py-3 pr-4 font-mono text-sm">$$</td>
