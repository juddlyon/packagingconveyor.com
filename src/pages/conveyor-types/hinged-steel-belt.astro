              <td class="py-3 pr-4">Yes (up to 1,000+ lbs/ft)</td>
              <td class="py-3 pr-4">Limited</td>
              <td class="py-3">No</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">Hot Material</td>
              <td class="py-3 pr-4">Up to 900&deg;F</td>
              <td class="py-3 pr-4">Up to 600&deg;F</td>
              <td class="py-3">Up to 400&deg;F</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3 pr-4 font-semibold text-ink">Coolant Handling</td>
              <td class="py-3 pr-4">Good (perforated option)</td>
              <td class="py-3 pr-4">Excellent (filtration built-in)</td>
              <td class="py-3">Limited</td>
            </tr>
            <tr class="border-b border-border">
