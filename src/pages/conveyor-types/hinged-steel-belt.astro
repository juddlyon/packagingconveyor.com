              <td class="py-3 pr-4">Up to 60&deg; (magnetic)</td>
              <td class="py-3 pr-4">Up to 45&deg;</td>
              <td class="py-3">Vertical possible</td>
            </tr>
            <tr>
              <td class="py-3 pr-4 font-semibold text-ink">Relative Cost</td>
              <td class="py-3 pr-4 font-mono text-sm">$$</td>
              <td class="py-3 pr-4 font-mono text-sm">$$</td>
