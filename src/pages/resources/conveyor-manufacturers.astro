  <script>
    const search = document.getElementById('dir-search');
    const catFilter = document.getElementById('dir-category');
    const typeFilter = document.getElementById('dir-type');
    const countEl = document.getElementById('dir-count');
    const emptyEl = document.getElementById('dir-empty');
    const resetBtn = document.getElementById('dir-reset');
    const rows = document.querySelectorAll('.dir-row');
    const cards = document.querySelectorAll('.dir-card');
    const sortBtns = document.querySelectorAll('.dir-sort');
    const tbody = document.getElementById('dir-tbody');
    const cardsContainer = document.getElementById('dir-cards');

    function applyFilters() {
      const q = (search?.value || '').toLowerCase().trim();
      const cat = catFilter?.value || '';
      const type = typeFilter?.value || '';
      let visible = 0;

      // Filter table rows
      rows.forEach(row => {
        const name = row.dataset.name || '';
        const known = row.dataset.known || '';
        const hq = row.dataset.hq || '';
        const industries = row.dataset.industries || '';
        const categories = JSON.parse(row.dataset.categories || '[]');
        const rowType = row.dataset.type || '';

        const matchSearch = !q || name.includes(q) || known.includes(q) || hq.includes(q) || industries.includes(q);
        const matchCat = !cat || categories.includes(cat);
        const matchType = !type || rowType === type;

        const show = matchSearch && matchCat && matchType;
        row.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      // Filter mobile cards
      cards.forEach(card => {
        const name = card.dataset.name || '';
        const known = card.dataset.known || '';
        const hq = card.dataset.hq || '';
        const industries = card.dataset.industries || '';
        const categories = JSON.parse(card.dataset.categories || '[]');
        const cardType = card.dataset.type || '';

        const matchSearch = !q || name.includes(q) || known.includes(q) || hq.includes(q) || industries.includes(q);
        const matchCat = !cat || categories.includes(cat);
        const matchType = !type || cardType === type;

        card.style.display = matchSearch && matchCat && matchType ? '' : 'none';
      });

      if (countEl) countEl.textContent = `${visible} ${visible === 1 ? 'company' : 'companies'}`;
      if (emptyEl) emptyEl.style.display = visible === 0 ? '' : 'none';
    }

    function applySorting(field) {
      if (!tbody || !cardsContainer) return;

      const sortRows = Array.from(rows);
      const sortCards = Array.from(cards);

      const getVal = (el) => {
        if (field === 'name') return el.dataset.name || '';
        if (field === 'hq') return el.dataset.hq || '';
        if (field === 'type') return el.dataset.type || '';
        return '';
      };

      sortRows.sort((a, b) => getVal(a).localeCompare(getVal(b)));
      sortCards.sort((a, b) => getVal(a).localeCompare(getVal(b)));

      sortRows.forEach(row => tbody.appendChild(row));
      sortCards.forEach(card => cardsContainer.appendChild(card));
    }

    search?.addEventListener('input', applyFilters);
    catFilter?.addEventListener('change', applyFilters);
    typeFilter?.addEventListener('change', applyFilters);

    sortBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        sortBtns.forEach(b => {
          b.classList.remove('text-accent', 'border-accent');
          b.classList.add('text-ink-muted', 'border-transparent');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.remove('text-ink-muted', 'border-transparent');
        btn.classList.add('text-accent', 'border-accent');
        btn.setAttribute('aria-pressed', 'true');
        applySorting(btn.dataset.sort);
      });
    });

    resetBtn?.addEventListener('click', () => {
      if (search) search.value = '';
      if (catFilter) catFilter.value = '';
      if (typeFilter) typeFilter.value = '';
      applyFilters();
    });
  </script>

</BaseLayout>
