---
import BaseLayout from '../../layouts/BaseLayout.astro';

const manufacturers = [
  { name: 'Dorner', website: 'https://www.dornerconveyors.com', knownFor: 'Precision low-profile belt conveyors, AquaGard/AquaPruf sanitary lines, tool-less belt removal, IP69K washdown', hq: 'Hartland, WI', categories: ['Belt', 'Sanitary'], industries: ['Food', 'Pharma', 'Packaging', 'Automation'], type: 'Manufacturer' },
  { name: 'Hytrol', website: 'https://www.hytrol.com', knownFor: 'Full roller and belt conveyor line, EZLogic zero-pressure accumulation, extensive integration partner network', hq: 'Jonesboro, AR', categories: ['Belt', 'Roller'], industries: ['Distribution', 'E-Commerce', 'Manufacturing'], type: 'Manufacturer' },
  { name: 'mk North America', website: 'https://www.mknorthamerica.com', knownFor: 'Aluminum-frame belt conveyors, modular design platform, quick-ship standard products', hq: 'Bloomfield, CT', categories: ['Belt'], industries: ['Industrial', 'Packaging', 'Automotive'], type: 'Manufacturer' },
  { name: 'Nercon', website: 'https://www.nerconconveyors.com', knownFor: 'Packaging line belt conveyors, accumulation tables, product handling and orientation', hq: 'Oshkosh, WI', categories: ['Belt', 'Sanitary'], industries: ['Food', 'Beverage', 'Packaging'], type: 'Manufacturer' },
  { name: 'Shuttleworth (ProMach)', website: 'https://www.shuttleworth.com', knownFor: 'Slip-torque roller belt technology, gentle product handling, zero-pressure accumulation', hq: 'Huntington, IN', categories: ['Belt', 'Roller'], industries: ['Consumer Goods', 'Food', 'Pharma'], type: 'Manufacturer' },
  { name: 'Span Tech', website: 'https://www.spantech.com', knownFor: 'Modular plastic belt conveyors, spiral conveyors, side-flexing chain, custom curved designs', hq: 'Glasgow, KY', categories: ['Modular/Chain', 'Belt'], industries: ['Food', 'Beverage', 'Packaging'], type: 'Manufacturer' },
  { name: 'Interroll', website: 'https://www.interroll.com', knownFor: 'Motorized roller drives (RollerDrive), modular conveyor platform, global availability', hq: 'Global', categories: ['Roller'], industries: ['Logistics', 'Distribution', 'Airports'], type: 'Manufacturer' },
  { name: 'Itoh Denki', website: 'https://www.itohdenki.com', knownFor: '24V DC motorized rollers (MDR), Power Moller technology, energy-efficient drives', hq: 'Schaumburg, IL', categories: ['Roller'], industries: ['Distribution', 'Manufacturing', 'Postal'], type: 'Manufacturer' },
  { name: 'TGW Logistics', website: 'https://www.tgw-group.com', knownFor: 'High-speed roller and belt conveyors, integrated warehouse automation systems', hq: 'Grand Rapids, MI', categories: ['Roller'], industries: ['Warehouse', 'E-Commerce', 'Retail'], type: 'Integrator' },
  { name: 'Conveyco', website: 'https://www.conveyco.com', knownFor: 'System integrator specializing in roller-based sortation and fulfillment systems', hq: 'Pittston, PA', categories: ['Roller'], industries: ['Distribution', 'E-Commerce', '3PL'], type: 'Integrator' },
  { name: 'Wire Belt Company', website: 'https://www.wirebelt.com', knownFor: 'Stainless steel wire mesh and flat-flex belting for cooling, frying, and baking', hq: 'Londonderry, NH', categories: ['Sanitary', 'Belt'], industries: ['Food Processing', 'Bakery', 'Snack'], type: 'Manufacturer' },
  { name: 'Heat and Control', website: 'https://www.heatandcontrol.com', knownFor: 'Complete food processing conveyor systems, vibratory conveyors, inspection integration', hq: 'Hayward, CA', categories: ['Sanitary', 'Specialty'], industries: ['Snack', 'Bakery', 'Prepared Foods'], type: 'Manufacturer' },
  { name: 'Key Technology (Duravant)', website: 'https://www.key.net', knownFor: 'Vibratory conveyors, optical sorting, digital sorting platforms for food processing', hq: 'Walla Walla, WA', categories: ['Sanitary', 'Specialty'], industries: ['Food Processing', 'Agriculture'], type: 'Manufacturer' },
  { name: 'Intralox (Laitram)', website: 'https://www.intralox.com', knownFor: 'Inventor of modular plastic belting, DirectDrive, ARB (activated roller belt), ThermoDrive homogeneous belting', hq: 'Harahan, LA', categories: ['Modular/Chain', 'Sanitary'], industries: ['Food', 'Beverage', 'Bakery', 'Distribution'], type: 'Manufacturer' },
  { name: 'Eaglestone', knownFor: 'Stainless steel sanitary conveyors, built-to-order for food packaging lines', hq: 'Naperville, IL', categories: ['Sanitary'], industries: ['Food Packaging', 'Bakery', 'Dairy'], type: 'Manufacturer' },
  { name: 'Regal Rexnord', website: 'https://www.regalrexnord.com', knownFor: 'MatTop modular belting, table-top chain (Rex and Marbett brands), power transmission', hq: 'Milwaukee, WI', categories: ['Modular/Chain'], industries: ['Beverage', 'Food', 'Packaging'], type: 'Manufacturer' },
  { name: 'Habasit', website: 'https://www.habasit.com', knownFor: 'HabasitLINK modular belting, fabric belting, timing belts, global service network', hq: 'Suwanee, GA', categories: ['Modular/Chain', 'Belt'], industries: ['Food', 'Packaging', 'Logistics'], type: 'Manufacturer' },
  { name: 'Volta Belting', website: 'https://www.voltabelting.com', knownFor: 'Homogeneous thermoplastic belting, no fabric layers, easy cleaning, welded seams', hq: 'Atlanta, GA', categories: ['Modular/Chain', 'Sanitary'], industries: ['Food', 'Meat', 'Poultry'], type: 'Manufacturer' },
  { name: 'UniTrak', website: 'https://www.unitrak.com', knownFor: 'Tubular drag and vacuum conveyors for powders, granules, and bulk materials', hq: 'Port Hope, ON', categories: ['Specialty'], industries: ['Food', 'Pharma', 'Chemical'], type: 'Manufacturer' },
  { name: 'Piab', website: 'https://www.piab.com', knownFor: 'Vacuum conveying systems for powders and granular materials, explosion-proof designs', hq: 'Global', categories: ['Specialty'], industries: ['Pharma', 'Food', 'Chemical'], type: 'Manufacturer' },
  { name: 'Bastian Solutions (Toyota)', website: 'https://www.bastiansolutions.com', knownFor: 'Pallet conveyors, heavy-duty roller conveyors, robotics, AGVs/AMRs, full warehouse automation', hq: 'Indianapolis, IN', categories: ['Roller', 'Specialty'], industries: ['Warehouse', 'E-Commerce', 'Manufacturing'], type: 'Integrator' },
  { name: 'Alba Manufacturing', website: 'https://www.albamfg.com', knownFor: 'Heavy-duty pallet and unit-load conveyors, chain-driven live roller, turntables', hq: 'Fairfield, OH', categories: ['Roller', 'Specialty'], industries: ['Manufacturing', 'Distribution', 'Packaging'], type: 'Manufacturer' },
  { name: 'Eriez', website: 'https://www.eriez.com', knownFor: 'Electromagnetic and mechanical vibratory feeders and conveyors, metal detection', hq: 'Erie, PA', categories: ['Specialty'], industries: ['Food', 'Pharma', 'Recycling'], type: 'Manufacturer' },
  { name: 'FMH Conveyors', website: 'https://www.fmhconveyors.com', knownFor: 'Telescoping and flexible conveyors for loading docks, parcel handling, and distribution', hq: 'Jonesboro, AR', categories: ['Specialty'], industries: ['Distribution', 'Parcel', 'E-Commerce'], type: 'Manufacturer' },
  { name: 'Dematic (KION Group)', website: 'https://www.dematic.com', knownFor: 'Warehouse automation, high-speed sortation, goods-to-person systems, global scale', hq: 'Atlanta, GA', categories: ['Roller', 'Specialty'], industries: ['Warehouse', 'E-Commerce', 'Retail'], type: 'Integrator' },
  { name: 'Honeywell Intelligrated', website: 'https://www.intelligrated.com', knownFor: 'Sortation systems, palletizing, warehouse execution software, lifecycle services', hq: 'Mason, OH', categories: ['Roller', 'Specialty'], industries: ['Warehouse', 'E-Commerce', 'Retail'], type: 'Integrator' },
  { name: 'ProMach', website: 'https://www.promachbuilt.com', knownFor: 'End-of-line packaging (Shuttleworth, Kleenline brands), stacking, case packing, conveying', hq: 'Covington, KY', categories: ['Belt', 'Sanitary'], industries: ['Food', 'Beverage', 'Consumer Goods'], type: 'Integrator' },
  { name: 'Kleenline (ProMach)', website: 'https://www.kleenline.com', knownFor: 'Sanitary stainless steel conveyors for food and pharmaceutical, easy-clean open-frame designs', hq: 'Newburgh, IN', categories: ['Sanitary', 'Belt'], industries: ['Food', 'Pharma', 'Packaging'], type: 'Manufacturer' },
];

// Build unique filter values
const allCategories = [...new Set(manufacturers.flatMap(m => m.categories))].sort();
const allTypes = [...new Set(manufacturers.map(m => m.type))].sort();

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://packagingconveyor.com/" },
    { "@type": "ListItem", "position": 2, "name": "Resources", "item": "https://packagingconveyor.com/resources/" },
    { "@type": "ListItem", "position": 3, "name": "Conveyor Manufacturers", "item": "https://packagingconveyor.com/resources/conveyor-manufacturers/" }
  ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Conveyor Manufacturers & Supplier Directory",
  "description": "Directory of conveyor manufacturers and suppliers organized by conveyor type, industry specialty, and service capability. Covers belt, roller, chain, modular plastic, sanitary, and specialty conveyor builders.",
  "url": "https://packagingconveyor.com/resources/conveyor-manufacturers/",
  "datePublished": "2026-03-12",
  "dateModified": new Date().toISOString().split('T')[0],
  "author": { "@type": "Organization", "name": "PackagingConveyor.com", "url": "https://packagingconveyor.com" },
  "publisher": { "@type": "Organization", "name": "PackagingConveyor.com", "url": "https://packagingconveyor.com" }
};

const directorySchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Conveyor Manufacturers & Suppliers Directory",
  "description": "Directory of conveyor manufacturers, integrators, and suppliers for packaging and material handling applications.",
  "numberOfItems": manufacturers.length,
  "itemListElement": manufacturers
    .sort((a, b) => a.name.localeCompare(b.name))
    .map((m, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Organization",
        "name": m.name,
        ...(m.website ? { "url": m.website } : {}),
        "description": m.knownFor,
        "address": { "@type": "PostalAddress", "addressLocality": m.hq },
      }
    }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Who are the largest conveyor manufacturers?",
      "acceptedAnswer": { "@type": "Answer", "text": "Major conveyor manufacturers include Hytrol, Dorner, Interroll, mk North America, Bastian Solutions (now a Toyota Advanced Logistics company), Dematic, Honeywell Intelligrated, and Siemens Logistics. In food and packaging specifically, Key Technology, Heat and Control, Intralox (a Laitram company), Wire Belt Company, and Nercon are well-known. The largest players vary by conveyor type and industry, a company that dominates warehouse sortation may not build sanitary food conveyors." }
    },
    {
      "@type": "Question",
      "name": "How do I choose a conveyor manufacturer?",
      "acceptedAnswer": { "@type": "Answer", "text": "Start by defining your application requirements: product type, weight, speed, environment (washdown, cleanroom, outdoor), and any regulatory standards (FDA, USDA, ATEX). Then evaluate manufacturers based on relevant experience in your industry, geographic proximity for service and installation, lead time, warranty terms, parts availability, and controls integration capability. Request references from similar installations and ask for a factory visit or demo if possible." }
    },
    {
      "@type": "Question",
      "name": "What is the difference between a conveyor manufacturer and an integrator?",
      "acceptedAnswer": { "@type": "Answer", "text": "A conveyor manufacturer designs and builds conveyor equipment, they fabricate frames, assemble drives, and ship the physical hardware. An integrator designs the overall material handling system, selects equipment from one or more manufacturers, handles controls and software, manages installation, and commissions the complete system. Some companies do both; others specialize in one role. For simple single-conveyor purchases, buying direct from a manufacturer is common. For complex multi-zone systems, an integrator adds value through system design and project management." }
    },
    {
      "@type": "Question",
      "name": "Do conveyor manufacturers sell direct or through distributors?",
      "acceptedAnswer": { "@type": "Answer", "text": "It varies by company. Some manufacturers like Dorner and mk North America sell both direct and through distributor networks. Others like Hytrol sell primarily through a network of integration partners. Large system manufacturers like Dematic and Honeywell Intelligrated typically sell direct through their own sales engineering teams. For packaging-specific conveyors, many manufacturers sell direct because the applications require custom engineering. Always check the manufacturer's website for their preferred sales channel in your region." }
    },
    {
      "@type": "Question",
      "name": "Can I buy conveyor parts from any manufacturer?",
      "acceptedAnswer": { "@type": "Answer", "text": "Many conveyor components, rollers, bearings, motors, VFDs, belting, and chain, are available from third-party suppliers and are not proprietary to the conveyor manufacturer. However, some manufacturers use proprietary frame profiles, belt lacing systems, or controller software that requires OEM parts. Before purchasing a conveyor, ask the manufacturer what percentage of wear parts are standard catalog items versus proprietary components. This affects long-term maintenance costs and parts availability." }
    }
  ]
};
---

<BaseLayout title="Conveyor Manufacturers &#x26; Supplier Directory | PackagingConveyor.com" description="Directory of conveyor manufacturers organized by type, industry, and capability. Belt, roller, modular plastic, sanitary, and specialty conveyor builders, with what each company is known for." canonical="https://packagingconveyor.com/resources/conveyor-manufacturers/" schema={[breadcrumbSchema, articleSchema, faqSchema, directorySchema]}>

  <!-- ═══ HERO + FILTERS (compact) ═══ -->
  <article>
    <section class="bg-blueprint relative overflow-hidden" id="directory">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14 relative z-10">
        <nav class="text-sm font-mono text-white/60 mb-6" aria-label="Breadcrumb">
          <a href="/" class="hover:text-white/70">Home</a>
          <span class="mx-2">/</span>
          <a href="/resources/" class="hover:text-white/70">Resources</a>
          <span class="mx-2">/</span>
          <span class="text-white/70">Manufacturer Directory</span>
        </nav>
        <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white tracking-wide uppercase leading-[0.95] mb-4">
          Conveyor <span class="text-accent-bright">Manufacturer</span> Directory
        </h1>
        <p class="text-base text-white/50 max-w-2xl mb-8">
          {manufacturers.length} manufacturers and integrators organized by conveyor type. Independent listings, no commissions. <a href="/resources/conveyor-companies/" class="text-accent-bright/70 hover:text-accent-bright">Find companies near you &rarr;</a>
        </p>

        <!-- Filters & Search (in hero) -->
        <div class="flex flex-col sm:flex-row gap-3">
          <div class="relative flex-1 max-w-md">
            <input
              type="text"
              id="dir-search"
              placeholder="Search by name, specialty, or location..."
              class="w-full pl-10 pr-4 py-3 bg-white/10 border border-white/20 text-white text-base font-sans placeholder:text-white/40 focus:outline-none focus:border-accent-bright focus:ring-1 focus:ring-accent-bright"
              autocomplete="off"
            />
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          </div>
          <select id="dir-category" class="px-4 py-3 pr-10 bg-white/10 border border-white/20 text-white text-base font-sans focus:outline-none focus:border-accent-bright cursor-pointer min-w-[160px] appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22rgba(255%2C255%2C255%2C0.5)%22%20stroke-width%3D%223%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpath%20d%3D%22M6%209l6%206%206-6%22%2F%3E%3C%2Fsvg%3E')] bg-[length:12px] bg-[right_12px_center] bg-no-repeat">
            <option value="">All Categories</option>
            {allCategories.map(c => <option value={c} class="text-ink bg-surface">{c}</option>)}
          </select>
          <select id="dir-type" class="px-4 py-3 pr-10 bg-white/10 border border-white/20 text-white text-base font-sans focus:outline-none focus:border-accent-bright cursor-pointer min-w-[160px] appearance-none bg-[url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2212%22%20height%3D%2212%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22rgba(255%2C255%2C255%2C0.5)%22%20stroke-width%3D%223%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpath%20d%3D%22M6%209l6%206%206-6%22%2F%3E%3C%2Fsvg%3E')] bg-[length:12px] bg-[right_12px_center] bg-no-repeat">
            <option value="">All Types</option>
            {allTypes.map(t => <option value={t} class="text-ink bg-surface">{t}</option>)}
          </select>
        </div>
      </div>
    </section>

    <!-- ═══ DIRECTORY TABLE ═══ -->
    <section class="py-6 bg-surface-dim">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Result count & sort -->
        <div class="flex items-center justify-between mb-4">
          <p id="dir-count" class="text-sm font-mono text-ink-muted">{manufacturers.length} companies</p>
          <div class="flex items-center gap-2 text-sm font-sans text-ink-muted">
            <span>Sort:</span>
            <button data-sort="name" class="dir-sort px-2 py-1 font-semibold text-accent border-b-2 border-accent" aria-pressed="true">Name</button>
            <button data-sort="hq" class="dir-sort px-2 py-1 font-semibold text-ink-muted hover:text-ink border-b-2 border-transparent" aria-pressed="false">Location</button>
            <button data-sort="type" class="dir-sort px-2 py-1 font-semibold text-ink-muted hover:text-ink border-b-2 border-transparent" aria-pressed="false">Type</button>
          </div>
        </div>

        <!-- Directory Table (desktop) -->
        <div class="hidden md:block overflow-x-auto -mx-4 px-4">
          <table class="w-full text-left border-collapse table-fixed" id="dir-table">
            <thead>
              <tr class="border-b-2 border-ink">
                <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4 pr-6" style="width:30%">Company</th>
                <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4 pr-4" style="width:40%">Known For</th>
                <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4 pr-4" style="width:14%">Category</th>
                <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4" style="width:16%">Headquarters</th>
              </tr>
            </thead>
            <tbody class="text-ink-muted" id="dir-tbody">
              {manufacturers.sort((a, b) => a.name.localeCompare(b.name)).map(m => {
                const domain = m.website ? new URL(m.website).hostname.replace('www.', '') : null;
                return (
                <tr class="border-b border-border dir-row align-top" data-name={m.name.toLowerCase()} data-categories={JSON.stringify(m.categories)} data-type={m.type} data-hq={m.hq.toLowerCase()} data-known={m.knownFor.toLowerCase()} data-industries={m.industries.join(' ').toLowerCase()}>
                  <td class="py-4 pr-6 font-semibold text-ink">
                    <div class="flex items-start gap-3">
                      {domain ? (
                        <img src={`https://www.google.com/s2/favicons?domain=${domain}&sz=32`} alt="" width="20" height="20" class="flex-shrink-0 rounded-sm mt-0.5" loading="lazy" />
                      ) : (
                        <div class="w-5 h-5 flex-shrink-0 rounded-sm mt-0.5 bg-ink/10"></div>
                      )}
                      <div>
                        {m.website ? (
                          <a href={m.website} target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-hover font-semibold inline-flex items-center gap-1.5 group text-base">
                            {m.name}
                            <svg class="w-3.5 h-3.5 opacity-30 group-hover:opacity-100 transition-opacity flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                          </a>
                        ) : (
                          <span>{m.name}</span>
                        )}
                        <div class="mt-1">
                          <span class={`text-xs font-mono font-semibold px-1.5 py-0.5 ${m.type === 'Integrator' ? 'bg-accent/10 text-accent' : 'bg-ink/5 text-ink-muted'}`}>{m.type}</span>
                        </div>
                      </div>
                    </div>
                  </td>
                  <td class="py-4 pr-4 text-sm leading-relaxed align-top">{m.knownFor}</td>
                  <td class="py-4 pr-4 align-top">
                    <div class="flex flex-wrap gap-1">
                      {m.categories.map(c => (
                        <span class="text-xs font-mono font-semibold px-2 py-0.5 bg-ink/5 text-ink-muted">{c}</span>
                      ))}
                    </div>
                  </td>
                  <td class="py-4 text-sm align-top">{m.hq}</td>
                </tr>
                );
              })}
            </tbody>
          </table>
        </div>

        <!-- Directory Cards (mobile) -->
        <div class="md:hidden space-y-2" id="dir-cards">
          {manufacturers.sort((a, b) => a.name.localeCompare(b.name)).map(m => {
            const domain = m.website ? new URL(m.website).hostname.replace('www.', '') : null;
            return (
            <div class="dir-card border border-border bg-surface p-4" data-name={m.name.toLowerCase()} data-categories={JSON.stringify(m.categories)} data-type={m.type} data-hq={m.hq.toLowerCase()} data-known={m.knownFor.toLowerCase()} data-industries={m.industries.join(' ').toLowerCase()}>
              <div class="flex items-center gap-3 mb-2">
                {domain ? (
                  <img src={`https://www.google.com/s2/favicons?domain=${domain}&sz=32`} alt="" width="24" height="24" class="flex-shrink-0 rounded-sm" loading="lazy" />
                ) : (
                  <div class="w-6 h-6 flex-shrink-0 rounded-sm bg-ink/10"></div>
                )}
                <div class="flex-1 min-w-0">
                  {m.website ? (
                    <a href={m.website} target="_blank" rel="noopener noreferrer" class="font-display text-lg font-bold uppercase tracking-wider text-accent hover:text-accent-hover inline-flex items-center gap-1.5 group">
                      {m.name}
                      <svg class="w-3.5 h-3.5 opacity-30 group-hover:opacity-100 transition-opacity flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                    </a>
                  ) : (
                    <span class="font-display text-lg font-bold uppercase tracking-wider text-ink">{m.name}</span>
                  )}
                </div>
                <span class={`text-xs font-mono font-semibold px-2 py-0.5 flex-shrink-0 ${m.type === 'Integrator' ? 'bg-accent/10 text-accent' : 'bg-ink/5 text-ink-muted'}`}>{m.type}</span>
              </div>
              <p class="text-sm text-ink-muted leading-relaxed mb-2">{m.knownFor}</p>
              <div class="flex items-center justify-between">
                <div class="flex flex-wrap gap-1">
                  {m.categories.map(c => (
                    <span class="text-xs font-mono font-semibold px-2 py-0.5 bg-ink/5 text-ink-muted">{c}</span>
                  ))}
                </div>
                <span class="text-ink-muted text-xs flex-shrink-0 ml-2">{m.hq}</span>
              </div>
            </div>
            );
          })}
        </div>

        <!-- No results message -->
        <div id="dir-empty" class="hidden py-16 text-center">
          <p class="text-lg text-ink-muted">No manufacturers match your filters.</p>
          <button id="dir-reset" class="mt-4 text-accent hover:text-accent-hover font-semibold text-base">Clear all filters</button>
        </div>
      </div>
    </section>

    <!-- ═══ CHOOSING A MANUFACTURER ═══ -->
    <section class="py-20 bg-surface" aria-labelledby="choosing-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="section-label text-accent mb-4">Selection Guide</div>
        <h2 id="choosing-heading" class="font-display text-4xl sm:text-5xl font-extrabold text-ink tracking-wide uppercase mb-10">
          How to <span class="text-accent">Choose</span> a Conveyor Manufacturer
        </h2>

        <div class="max-w-4xl space-y-8">
          <div>
            <h3 class="font-display text-2xl font-bold uppercase tracking-wider text-ink mb-4">Start With Your Application, Not the Manufacturer</h3>
            <p class="text-lg text-ink-muted leading-relaxed">
              Define your requirements before contacting vendors: product dimensions and weight, throughput rate, environment (ambient, washdown, cleanroom, outdoor), regulatory requirements (FDA, USDA, ATEX, Class 100), and integration points with upstream and downstream equipment. A clear specification reduces quote variance and helps you compare vendors on equal terms. See our <a href="/resources/conveyor-cost-guide/" class="text-accent hover:text-accent-hover font-semibold">cost guide</a> for factors that drive pricing.
            </p>
          </div>

          <div>
            <h3 class="font-display text-2xl font-bold uppercase tracking-wider text-ink mb-4">Evaluate Industry Experience</h3>
            <p class="text-lg text-ink-muted leading-relaxed">
              A manufacturer that has built 200 <a href="/industries/food-conveyors/bakery/" class="text-accent hover:text-accent-hover font-semibold">bakery conveyors</a> will anticipate problems, flour dust ingress, high-temperature exposure, sanitation protocols, that a general-purpose builder may not. Ask for case studies or references in your specific industry. If the manufacturer cannot provide them, that does not disqualify them, but it means you should scrutinize their design more carefully.
            </p>
          </div>

          <div>
            <h3 class="font-display text-2xl font-bold uppercase tracking-wider text-ink mb-4">Consider Total Cost of Ownership</h3>
            <p class="text-lg text-ink-muted leading-relaxed">
              The purchase price is one component of conveyor cost. Long-term costs include energy consumption, <a href="/resources/conveyor-parts/" class="text-accent hover:text-accent-hover font-semibold">replacement parts</a> (belts, rollers, bearings, motors), maintenance labor, and downtime. A conveyor with standard catalog parts from multiple suppliers will cost less to maintain than one with proprietary components available only from the OEM. Ask manufacturers what percentage of wear parts are standard versus proprietary.
            </p>
          </div>

          <div>
            <h3 class="font-display text-2xl font-bold uppercase tracking-wider text-ink mb-4">Geographic Proximity Matters</h3>
            <p class="text-lg text-ink-muted leading-relaxed">
              For installation support, emergency service, and parts delivery, proximity reduces response time and travel costs. This does not mean you must buy local, many manufacturers service nationally, but a company with a service center within a few hours of your facility can respond to breakdowns faster. See our <a href="/resources/conveyor-companies/" class="text-accent hover:text-accent-hover font-semibold">conveyor companies near you</a> guide for regional search strategies.
            </p>
          </div>

          <div>
            <h3 class="font-display text-2xl font-bold uppercase tracking-wider text-ink mb-4">Get Multiple Quotes</h3>
            <p class="text-lg text-ink-muted leading-relaxed">
              Request quotes from at least 2-3 manufacturers. Ensure all vendors are quoting on the same specification: same conveyor type, length, width, speed, load capacity, material of construction, controls scope, and installation scope. Price differences of 20-40% between qualified vendors are common and reflect differences in manufacturing approach, overhead structure, and local market conditions, not necessarily quality differences.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ MANUFACTURER ASSOCIATIONS ═══ -->
    <section class="py-20 bg-ink-light" aria-labelledby="associations-heading">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="section-label text-accent-bright mb-4">Industry Resources</div>
        <h2 id="associations-heading" class="font-display text-4xl sm:text-5xl font-extrabold text-white tracking-wide uppercase mb-10">
          Industry <span class="text-accent-bright">Associations</span> &#x26; Directories
        </h2>

        <div class="max-w-4xl space-y-6">
          <p class="text-lg text-white/60 leading-relaxed">
            Beyond this directory, the following industry associations maintain member directories that can help you identify conveyor manufacturers for specific applications:
          </p>

          <div class="grid md:grid-cols-2 gap-6">
            <div class="border border-white/10 p-6">
              <h3 class="font-display text-lg font-bold uppercase tracking-wider text-white mb-2"><a href="https://www.cema.org" target="_blank" rel="noopener noreferrer" class="text-accent-bright hover:text-white font-semibold">CEMA</a></h3>
              <p class="text-white/60 leading-relaxed">Conveyor Equipment Manufacturers Association, trade association for North American conveyor manufacturers. Member directory organized by conveyor type.</p>
            </div>
            <div class="border border-white/10 p-6">
              <h3 class="font-display text-lg font-bold uppercase tracking-wider text-white mb-2"><a href="https://www.mhi.org" target="_blank" rel="noopener noreferrer" class="text-accent-bright hover:text-white font-semibold">MHI</a></h3>
              <p class="text-white/60 leading-relaxed">Material Handling Industry, parent organization covering conveyors, AGVs, robotics, and warehouse automation. Hosts ProMat and MODEX trade shows.</p>
            </div>
            <div class="border border-white/10 p-6">
              <h3 class="font-display text-lg font-bold uppercase tracking-wider text-white mb-2"><a href="https://www.pmmi.org" target="_blank" rel="noopener noreferrer" class="text-accent-bright hover:text-white font-semibold">PMMI</a></h3>
              <p class="text-white/60 leading-relaxed">Association for Packaging and Processing Technologies, members include packaging machinery and conveyor manufacturers. Hosts PACK EXPO trade shows.</p>
            </div>
            <div class="border border-white/10 p-6">
              <h3 class="font-display text-lg font-bold uppercase tracking-wider text-white mb-2">Thomas</h3>
              <p class="text-white/60 leading-relaxed">Thomasnet.com, industrial supplier directory with detailed company profiles, certifications, and capabilities filtering for conveyor manufacturers.</p>
            </div>
          </div>
        </div>
