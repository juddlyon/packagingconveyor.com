                <td class="py-4 pr-4">Cartons/hour, orders/hour</td>
                <td class="py-4">Products/minute, cases/minute</td>
              </tr>
              <tr class="border-b border-border">
                <td class="py-4 pr-4 font-semibold text-ink">Conveyor types</td>
                <td class="py-4 pr-4"><a href="/conveyor-types/roller-conveyors/" class="text-accent hover:text-accent-hover">Roller</a>, <a href="/conveyor-types/mdr-conveyors/" class="text-accent hover:text-accent-hover">MDR</a>, sortation</td>
                <td class="py-4">Belt, tabletop, <a href="/conveyor-types/accumulation-conveyors/" class="text-accent hover:text-accent-hover">accumulation</a>, indexing</td>
              </tr>
              <tr class="border-b border-border">
                <td class="py-4 pr-4 font-semibold text-ink">Key integration</td>
                <td class="py-4 pr-4">WMS, WCS, barcode/RFID</td>
                <td class="py-4">OEM machines, PLC, HMI, vision</td>
              </tr>
