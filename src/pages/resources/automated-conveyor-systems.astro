                <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4 pr-4">Warehouse Automation</th>
                <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4">Packaging Line Automation</th>
              </tr>
            </thead>
