};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Conveyor Belt Types & Material Selection Guide",
  "description": "Complete guide to conveyor belt types and materials , rubber, PVC, polyurethane, silicone, modular plastic, and metal belts. FDA/USDA options, temperature ratings, and selection criteria for packaging lines.",
  "url": "https://packagingconveyor.com/resources/conveyor-belting/",
