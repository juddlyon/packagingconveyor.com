const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do you calculate conveyor belt pull?",
      "acceptedAnswer": { "@type": "Answer", "text": "Belt pull (also called effective tension) is calculated as: Te = F × L × (W_belt + W_product) + (W_product × H), where F is the friction factor (typically 0.03-0.06 for slider bed conveyors), L is conveyor length in feet, W_belt is belt weight per linear foot, W_product is product load per linear foot, and H is the elevation change in feet. Belt pull is measured in pounds and determines the required motor horsepower and belt tensile strength." }
    },
    {
      "@type": "Question",
      "name": "How do you size a conveyor motor?",
      "acceptedAnswer": { "@type": "Answer", "text": "Motor horsepower is calculated as: HP = (belt pull in pounds × belt speed in FPM) / 33,000. Apply a service factor of 1.5 for normal duty or 2.0 for heavy duty and frequent starts/stops. Round up to the next standard motor size (0.5, 0.75, 1, 1.5, 2, 3, 5 HP). An oversized motor wastes energy; an undersized motor overheats and fails prematurely. For variable speed applications, use a VFD (variable frequency drive) to adjust motor speed without changing pulleys." }
    },
    {
      "@type": "Question",
      "name": "What is the maximum incline angle for a conveyor?",
      "acceptedAnswer": { "@type": "Answer", "text": "Maximum incline angle depends on the product and belt surface. Smooth belt with cartons: 15-18 degrees maximum. Rough-top belt with cartons: 22-25 degrees. Cleated belt: up to 45 degrees. Cleated belt with sidewalls: up to 90 degrees (vertical). Bottles and round containers require lower angles , typically 5-10 degrees maximum before tipping. Factors include product center of gravity, surface friction between product and belt, and vibration from the conveyor drive." }
    },
    {
      "@type": "Question",
      "name": "How do you calculate conveyor throughput?",
      "acceptedAnswer": { "@type": "Answer", "text": "Conveyor throughput in products per minute equals belt speed (in feet per minute) divided by product pitch (center-to-center spacing in feet). Product pitch is the product length plus the gap between products. Example: a belt running at 80 FPM with a 12-inch product pitch (1 foot) delivers 80 products per minute. For multi-lane conveyors, multiply single-lane throughput by the number of lanes." }
    }
