  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://packagingconveyor.com/" },
    { "@type": "ListItem", "position": 2, "name": "Resources", "item": "https://packagingconveyor.com/resources/" },
    { "@type": "ListItem", "position": 3, "name": "Motors & Drives", "item": "https://packagingconveyor.com/resources/conveyor-motors-drives/" }
  ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Conveyor Motors & Drive Systems Guide",
  "description": "Complete guide to conveyor motors and drives: AC induction motors, gear motors, servo motors, VFDs, motorized drive rollers (MDR), drum motors, motor sizing, and energy efficiency standards (IE3/IE4).",
  "url": "https://packagingconveyor.com/resources/conveyor-motors-drives/",
  "datePublished": "2026-03-12",
  "publisher": { "@type": "Organization", "name": "PackagingConveyor.com", "url": "https://packagingconveyor.com" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What type of motor is used on a conveyor?",
      "acceptedAnswer": { "@type": "Answer", "text": "Most packaging conveyors use AC induction motors with gear reducers (gear motors). Gear motors provide the low speed (10-200 RPM) and high torque that conveyors require. For variable speed, a VFD (variable frequency drive) controls the AC motor speed electronically. Servo motors are used on indexing conveyors requiring precise position control. Motorized drive rollers (MDR) use small 24V DC motors embedded inside conveyor rollers for zone-based accumulation systems. Drum motors integrate the motor and gearbox inside the drive pulley for compact, washdown-friendly belt conveyors." }
    },
    {
      "@type": "Question",
      "name": "What is a VFD and why is it used on conveyors?",
      "acceptedAnswer": { "@type": "Answer", "text": "A VFD (variable frequency drive), also called an adjustable frequency drive or inverter, controls AC motor speed by varying the frequency and voltage of the electrical power supplied to the motor. VFDs allow conveyor speed adjustment from near-zero to above rated speed without mechanical changes. Benefits include soft starting (reduces mechanical stress), speed matching between conveyors and machines, energy savings at reduced speeds, and dynamic braking. Select a VFD that supports the required communication protocol (Ethernet/IP, PROFINET, or EtherCAT) and matches the motor's full-load amperage." }
    },
    {
      "@type": "Question",
      "name": "What is an MDR motor?",
      "acceptedAnswer": { "@type": "Answer", "text": "An MDR (motorized drive roller) motor is a small brushless DC motor embedded inside a conveyor roller. The motor, gearbox, and roller form a single integrated unit. MDR motors operate on 24V DC power and are controlled by zone controller cards. Each zone (typically 18-36 inches long) has one MDR that drives 2-5 adjacent idle rollers via O-ring or poly-V belts. MDR systems provide zero-pressure accumulation, low noise, and energy efficiency because only zones with product are powered. MDR rollers are available from several global suppliers specializing in motorized roller technology." }
    },
    {
      "@type": "Question",
      "name": "How do you size a motor for a conveyor?",
      "acceptedAnswer": { "@type": "Answer", "text": "Motor sizing uses the formula HP = (belt pull × belt speed in FPM) / 33,000. Belt pull is calculated from conveyor length, product weight, belt weight, friction factor, and elevation change. Apply a service factor (1.5 for normal duty, 2.0 for heavy duty) to account for starting torque and load variation, then round up to the next standard NEMA motor size. Oversizing wastes energy; undersizing causes overheating and premature failure." }
    }
  ]
};
