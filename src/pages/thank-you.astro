---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Request Received | PackagingConveyor.com" description="Your conveyor quote request has been received. We'll match you with at least 3 qualified suppliers within 1 business day.">
  <section class="py-24 bg-surface-dim bg-dots">
    <div class="max-w-xl mx-auto px-4 text-center">
      <div class="w-20 h-20 rounded-full bg-green/10 flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
      </div>
      <h1 class="text-4xl font-800 text-ink tracking-wide mb-4">Request Received</h1>
      <p class="text-ink-muted text-lg mb-8 leading-relaxed">
        We're reviewing your requirements and matching you with <strong class="text-ink">at least 3 qualified conveyor suppliers</strong>. Expect to hear from them within 1 business day.
      </p>
      <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-accent text-white font-display font-bold text-sm tracking-widest uppercase hover:bg-accent-hover transition-colors">
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
