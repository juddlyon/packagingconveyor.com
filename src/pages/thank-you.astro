---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Thank You | PackagingConveyor.com" description="Thanks for visiting PackagingConveyor.com , the packaging industry's most comprehensive conveyor resource.">
  <section class="py-24 bg-surface-dim bg-dots">
    <div class="max-w-xl mx-auto px-4 text-center">
      <div class="w-20 h-20 rounded-full bg-green/10 flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-green" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
      </div>
      <h1 class="text-4xl sm:text-5xl font-800 text-ink tracking-wide mb-4">Thank You</h1>
      <p class="text-ink-muted text-lg mb-8 leading-relaxed">
        Thanks for using PackagingConveyor.com. Continue exploring our technical guides and conveyor resources.
      </p>
      <a href="/" class="inline-flex items-center gap-2 px-8 py-4 bg-accent text-white font-display font-bold text-base tracking-widest uppercase hover:bg-accent-hover transition-colors">
        Back to Home
      </a>
    </div>
  </section>
</BaseLayout>
