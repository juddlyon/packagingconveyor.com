---
import BaseLayout from '../layouts/BaseLayout.astro';
const conveyorTypes = [
  { name: 'Roller', slug: 'roller-conveyors', desc: 'Gravity, powered & MDR roller systems' },
  { name: 'Accumulation', slug: 'accumulation-conveyors', desc: 'Zero-pressure zone buffering' },
  { name: 'Belt', slug: 'flat-belt-conveyors', desc: 'Flat, cleated & modular belt' },
  { name: 'Transfer', slug: 'transfer-conveyors', desc: 'Right-angle & multi-directional' },
  { name: 'Spiral', slug: 'spiral-conveyors', desc: 'Vertical elevation change' },
  { name: 'Chain', slug: 'chain-conveyors', desc: 'Drag, slat & overhead chain' },
  { name: 'Sortation', slug: 'diverting-merging', desc: 'Diverting & merging systems' },
  { name: 'Pallet', slug: '/industries/packaging-line-conveyors/pallet', desc: 'Heavy-duty pallet handling' },
  { name: 'Screw', slug: 'screw-conveyors', desc: 'Bulk auger conveying' },
  { name: 'Tabletop', slug: 'tabletop-conveyors', desc: 'Bottles, cans & cartons' },
  { name: 'Vibratory', slug: 'vibratory-conveyors', desc: 'Parts feeders & hoppers' },
];

const industries = [
  { name: 'Food & Beverage', slug: 'food-conveyors', desc: 'Sanitary, USDA, washdown-rated conveyor systems for food processing and packaging lines', tags: ['USDA', '3-A', 'IP69K'] },
  { name: 'Packaging Lines', slug: 'packaging-line-conveyors', desc: 'Primary, secondary & tertiary packaging line conveyor integration and layout', tags: ['Case', 'Pallet', 'Wrap'] },
  { name: 'Pharmaceutical', slug: 'pharmaceutical-conveyors', desc: 'Cleanroom and GMP-compliant conveyor systems for pharma manufacturing', tags: ['GMP', 'ISO 5-8', 'HEPA'] },
  { name: 'Automotive', slug: 'automotive-conveyors', desc: 'Assembly line, paint line & lineside delivery conveyor systems', tags: ['Assembly', 'Paint', 'AGV'] },
];

const functions = [
  { name: 'Accumulate & Buffer', slug: 'storage-conveyors', desc: 'Buffer product between processes to absorb line stops' },
  { name: 'Collate & Lane', slug: 'collating-laning', desc: 'Distribute product from one lane across multiple lanes' },
  { name: 'Load Trays', slug: 'tray-loading', desc: 'Automatic tray loading, denesting & unloading' },
  { name: 'Index & Position', slug: 'indexing-conveyors', desc: 'Precision stop-and-go positioning for robotics' },
  { name: 'Reject & Divert', slug: 'reject-systems', desc: 'Remove failed QC product from the main line' },
  { name: 'Turn & Orient', slug: 'product-handling', desc: 'Rotate, flip or invert product on the conveyor' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a packaging conveyor system cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Packaging conveyor system pricing depends on type, length, load capacity, controls, and environment (e.g. food-grade or cleanroom). Gravity roller sections are the lowest cost, while fully integrated packaging lines with PLC controls and sortation are the highest. Key cost factors include conveyor length, belt/roller material, motor type, accumulation features, and installation complexity. Contact manufacturers directly for project-specific quotes."
      }
    },
    {
      "@type": "Question",
      "name": "What type of conveyor is best for packaging lines?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The best conveyor type depends on your product, speed, and application. Belt conveyors work for lightweight and irregular shapes. Roller conveyors (gravity or powered) suit cases and cartons. MDR conveyors provide zone-based accumulation with low maintenance. Tabletop chain conveyors handle bottles and cans. Spiral conveyors save floor space for elevation changes. Most packaging lines use multiple conveyor types together."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between MDR and powered roller conveyors?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "MDR (Motor Driven Roller) conveyors use small brushless DC motors inside individual rollers, controlled in independent zones for zero-pressure accumulation. Powered roller conveyors use a single external motor driving all rollers via belt or chain. MDR is quieter, more energy efficient (50%+ savings), and provides better product control. Powered roller has lower upfront cost and is simpler for continuous-flow applications."
      }
    },
    {
      "@type": "Question",
      "name": "What conveyor speed do I need for my packaging line?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Conveyor speed depends on your throughput requirement. A typical formula: Speed (FPM) = (Products per minute × Product length in feet) + gap allowance. Common packaging line speeds: case conveyors run 50-200 FPM, bottle lines run 20-100 FPM, pallet conveyors run 20-60 FPM. Always add 10-15% speed headroom above your peak production rate to prevent the conveyor from becoming a bottleneck."
      }
    },
    {
      "@type": "Question",
      "name": "What is zero-pressure accumulation on a conveyor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Zero-pressure accumulation (ZPA) means products stop and queue on a conveyor without touching each other or building up backpressure. Each zone has its own sensor and drive control. When a downstream zone is occupied, the upstream zone stops its product with a gap between them. This prevents product damage, label scuffing, and carton crushing. ZPA is critical for fragile products and is most commonly implemented using MDR (Motor Driven Roller) conveyors."
      }
    }
  ]
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Packaging Conveyor Systems: Complete Guide to 30+ Conveyor Types",
  "description": "Technical guides and selection criteria for over 30 packaging conveyor types across food, pharmaceutical, automotive, and warehouse applications.",
  "url": "https://packagingconveyor.com/",
  "isPartOf": { "@type": "WebSite", "name": "PackagingConveyor.com", "url": "https://packagingconveyor.com" },
  "about": {
    "@type": "Thing",
    "name": "Packaging Conveyor Systems",
    "description": "Conveyor systems used in packaging operations including belt, roller, MDR, accumulation, spiral, chain, and sortation conveyors"
  }
};
---

<BaseLayout
  title="Packaging Conveyor Systems | Complete Guide to 30+ Types & Specs"
  description="Technical guides and selection criteria for 30+ packaging conveyor types. Specs, comparisons, and engineering data for plant engineers and packaging managers."
  canonical="https://packagingconveyor.com/"
  schema={[faqSchema, webPageSchema]}
>

  <!-- ═══ HERO ═══ -->
  <section class="bg-ink relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-20 lg:py-24">
      <div class="max-w-3xl">
        <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-800 text-white tracking-wide leading-[0.95] mb-6">
          The Packaging Conveyor Reference
        </h1>
        <p class="text-lg sm:text-xl text-white/50 max-w-2xl mb-10 leading-relaxed font-body">
          Technical guides and selection criteria for <strong class="text-white/80">30+ conveyor types</strong> across food, pharmaceutical, automotive, and warehouse applications. Independent. No vendor bias.
        </p>
        <nav class="flex flex-wrap gap-3 font-sans text-sm" aria-label="Quick navigation">
          <a href="/conveyor-types/" class="px-5 py-2.5 bg-accent text-white font-semibold hover:bg-accent-hover transition-colors">Browse by Type</a>
          <a href="/industries/" class="px-5 py-2.5 border border-white/20 text-white/80 font-semibold hover:border-white/40 hover:text-white transition-colors">Browse by Industry</a>
          <a href="/resources/conveyor-cost-guide/" class="px-5 py-2.5 border border-white/20 text-white/80 font-semibold hover:border-white/40 hover:text-white transition-colors">Pricing Guide</a>
        </nav>
      </div>
    </div>
  </section>

  <!-- ═══ COMPARISON TABLE ═══ -->
  <section class="py-16 sm:py-20 bg-surface" aria-labelledby="comparison-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
        <div>
          <h2 id="comparison-heading" class="font-display text-3xl sm:text-4xl font-700 text-ink tracking-wide">
            Conveyor Type Comparison
          </h2>
          <p class="text-ink-muted mt-2 max-w-xl">Side-by-side specs for the most common packaging conveyor types.</p>
        </div>
        <a href="/conveyor-types/" class="text-sm font-sans font-semibold text-accent hover:text-accent-hover transition-colors flex items-center gap-1 shrink-0">
          All 30+ types
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>

      <div class="overflow-x-auto -mx-4 px-4">
        <table class="w-full text-left border-collapse min-w-[700px]">
          <thead>
            <tr class="border-b-2 border-ink">
              <th class="font-sans text-sm font-semibold uppercase tracking-wider text-ink-muted py-3 pr-4">Type</th>
              <th class="font-sans text-sm font-semibold uppercase tracking-wider text-ink-muted py-3 pr-4">Best For</th>
              <th class="font-sans text-sm font-semibold uppercase tracking-wider text-ink-muted py-3 pr-4">Speed Range</th>
              <th class="font-sans text-sm font-semibold uppercase tracking-wider text-ink-muted py-3 pr-4">Relative Cost</th>
              <th class="font-sans text-sm font-semibold uppercase tracking-wider text-ink-muted py-3">Load</th>
            </tr>
          </thead>
          <tbody class="text-base">
            <tr class="border-b border-border">
              <td class="py-3.5 pr-4 font-semibold"><a href="/conveyor-types/flat-belt-conveyors/" class="text-accent hover:text-accent-hover font-semibold">Belt</a></td>
              <td class="py-3.5 pr-4 text-ink-muted">Lightweight, irregular shapes</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">20-400 FPM</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">$$</td>
              <td class="py-3.5 font-mono text-sm text-ink-muted">Up to 100 lbs</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3.5 pr-4 font-semibold"><a href="/conveyor-types/roller-conveyors/" class="text-accent hover:text-accent-hover font-semibold">Gravity Roller</a></td>
              <td class="py-3.5 pr-4 text-ink-muted">Cases, cartons, totes</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">Gravity</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">$</td>
              <td class="py-3.5 font-mono text-sm text-ink-muted">Up to 200 lbs</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3.5 pr-4 font-semibold"><a href="/conveyor-types/roller-conveyors/" class="text-accent hover:text-accent-hover font-semibold">Powered Roller</a></td>
              <td class="py-3.5 pr-4 text-ink-muted">Continuous flow, cases</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">30-200 FPM</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">$$$</td>
              <td class="py-3.5 font-mono text-sm text-ink-muted">Up to 500 lbs</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3.5 pr-4 font-semibold"><a href="/conveyor-types/mdr-conveyors/" class="text-accent hover:text-accent-hover font-semibold">MDR</a></td>
              <td class="py-3.5 pr-4 text-ink-muted">Accumulation, zone control</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">30-180 FPM</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">$$$</td>
              <td class="py-3.5 font-mono text-sm text-ink-muted">Up to 250 lbs</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3.5 pr-4 font-semibold"><a href="/conveyor-types/spiral-conveyors/" class="text-accent hover:text-accent-hover font-semibold">Spiral</a></td>
              <td class="py-3.5 pr-4 text-ink-muted">Elevation change, small footprint</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">50-200 FPM</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">$$$$</td>
              <td class="py-3.5 font-mono text-sm text-ink-muted">Up to 75 lbs</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-3.5 pr-4 font-semibold"><a href="/conveyor-types/tabletop-conveyors/" class="text-accent hover:text-accent-hover font-semibold">Tabletop Chain</a></td>
              <td class="py-3.5 pr-4 text-ink-muted">Bottles, cans, small cartons</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">20-100 FPM</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">$$</td>
              <td class="py-3.5 font-mono text-sm text-ink-muted">Up to 50 lbs</td>
            </tr>
            <tr>
              <td class="py-3.5 pr-4 font-semibold"><a href="/industries/packaging-line-conveyors/pallet/" class="text-accent hover:text-accent-hover font-semibold">Pallet</a></td>
              <td class="py-3.5 pr-4 text-ink-muted">Heavy palletized loads</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">20-60 FPM</td>
              <td class="py-3.5 pr-4 font-mono text-sm text-ink-muted">$$$$</td>
              <td class="py-3.5 font-mono text-sm text-ink-muted">Up to 4,000 lbs</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-ink-muted mt-4 font-sans">$ = lowest relative cost, $$$$ = highest. Actual pricing varies by length, configuration, materials, and manufacturer. <a href="/resources/conveyor-cost-guide/" class="text-accent hover:text-accent-hover font-semibold">See our cost factors guide</a>.</p>
    </div>
  </section>

  <!-- ═══ CONVEYOR TYPES ═══ -->
  <section class="py-16 sm:py-20 bg-surface-dim" aria-labelledby="types-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10">
        <h2 id="types-heading" class="font-display text-3xl sm:text-4xl font-700 text-ink tracking-wide">
          Browse by Conveyor Type
        </h2>
        <a href="/conveyor-types/" class="text-sm font-sans font-semibold text-accent hover:text-accent-hover transition-colors flex items-center gap-1 shrink-0">
          View all 30+ types
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-px bg-border">
        {conveyorTypes.map((type) => (
          <a
            href={type.slug.startsWith('/') ? `${type.slug}/` : `/conveyor-types/${type.slug}/`}
            class="bg-surface-dim hover:bg-surface p-5 group transition-colors"
          >
            <div class="font-display text-lg font-bold tracking-wide text-ink group-hover:text-accent transition-colors">{type.name}</div>
            <div class="text-sm text-ink-muted mt-1 font-sans">{type.desc}</div>
          </a>
        ))}
        <a
          href="/conveyor-types/"
          class="bg-accent/5 hover:bg-accent/10 p-5 group transition-colors"
        >
          <div class="font-display text-lg font-bold tracking-wide text-accent group-hover:text-accent-hover transition-colors">All 30+ Types</div>
          <div class="text-sm text-ink-muted mt-1 font-sans">Complete conveyor guide</div>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ ABOUT THIS RESOURCE ═══ -->
  <section class="py-16 sm:py-20 bg-surface" aria-labelledby="about-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
        <div class="lg:col-span-3">
          <h2 id="about-heading" class="font-display text-3xl sm:text-4xl font-700 text-ink tracking-wide mb-6">
            The Conveyor Guide That Should Have Existed
          </h2>
          <div class="text-lg text-ink-muted leading-relaxed space-y-4">
            <p>
              Manufacturer sites only show <em>their</em> products. Distributor sites are catalogs with no engineering context. Neither helps you compare conveyor types or spec a system.
            </p>
            <p>
              <strong class="text-ink">PackagingConveyor.com is the neutral technical resource.</strong> Speed calculations, throughput formulas, selection criteria, and head-to-head comparisons across 30+ conveyor types in food & beverage, pharmaceutical, automotive, and warehouse applications.
            </p>
            <p>
              Use this site to spec your system, compare options, and build an RFQ you can send to any vendor.
            </p>
          </div>
        </div>
        <aside class="lg:col-span-2 font-sans">
          <div class="border-l-2 border-accent pl-6 space-y-6">
            <div>
              <div class="font-display text-4xl font-bold text-ink tracking-wide">98</div>
              <div class="text-sm text-ink-muted mt-0.5">In-depth technical guides</div>
            </div>
            <div>
              <div class="font-display text-4xl font-bold text-ink tracking-wide">30+</div>
              <div class="text-sm text-ink-muted mt-0.5">Conveyor types covered</div>
            </div>
            <div>
              <div class="font-display text-4xl font-bold text-ink tracking-wide">4</div>
              <div class="text-sm text-ink-muted mt-0.5">Industry verticals</div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- ═══ INDUSTRIES ═══ -->
  <section class="py-16 sm:py-20 bg-surface-dim" aria-labelledby="industries-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="industries-heading" class="font-display text-3xl sm:text-4xl font-700 text-ink tracking-wide mb-10">
        Conveyors by Industry
      </h2>

      <div class="grid md:grid-cols-2 gap-5">
        {industries.map((ind) => (
          <a href={`/industries/${ind.slug}/`} class="card group p-6 flex flex-col">
            <div class="flex items-start justify-between mb-2">
              <h3 class="font-display text-xl font-bold tracking-wide text-ink group-hover:text-accent transition-colors">{ind.name}</h3>
              <svg class="w-5 h-5 text-ink-muted group-hover:text-accent group-hover:translate-x-0.5 transition-all flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
            <p class="text-base text-ink-muted mb-4 leading-relaxed">{ind.desc}</p>
            <div class="flex flex-wrap gap-2 mt-auto font-sans">
              {ind.tags.map(tag => (
                <span class="text-xs font-semibold px-2.5 py-0.5 bg-ink/5 text-ink-muted">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FUNCTIONS ═══ -->
  <section class="py-16 sm:py-20 bg-ink-light" aria-labelledby="functions-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10">
        <div>
          <h2 id="functions-heading" class="font-display text-3xl sm:text-4xl font-700 text-white tracking-wide">
            What Does Your Line Need to Do?
          </h2>
          <p class="mt-2 text-white/50 max-w-xl">Think by problem, not equipment. Start with the function.</p>
        </div>
        <a href="/conveyor-functions/" class="text-sm font-sans font-semibold text-accent-bright hover:text-white transition-colors flex items-center gap-1 shrink-0">
          All functions
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-white/10">
        {functions.map((fn) => (
          <a href={`/conveyor-functions/${fn.slug}/`} class="group p-6 bg-ink-light hover:bg-white/[0.04] transition-colors">
            <h3 class="font-display text-lg font-bold tracking-wide text-white group-hover:text-accent-bright transition-colors mb-1.5">{fn.name}</h3>
            <p class="text-sm text-white/50 leading-relaxed font-sans">{fn.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ RESOURCES ═══ -->
  <section class="py-16 sm:py-20 bg-surface" aria-labelledby="resources-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="resources-heading" class="font-display text-3xl sm:text-4xl font-700 text-ink tracking-wide mb-10">
        Engineering Resources
      </h2>

      <div class="grid md:grid-cols-3 gap-5">
        <a href="/resources/conveyor-manufacturers/" class="card group p-6">
          <h3 class="font-display text-lg font-bold tracking-wide text-ink group-hover:text-accent transition-colors mb-2">Manufacturer Directory</h3>
          <p class="text-base text-ink-muted">Conveyor manufacturers and integrators filtered by type, industry, and capability.</p>
        </a>

        <a href="/resources/conveyor-cost-guide/" class="card group p-6">
          <h3 class="font-display text-lg font-bold tracking-wide text-ink group-hover:text-accent transition-colors mb-2">Cost & Pricing Guide</h3>
          <p class="text-base text-ink-muted">Cost factors by conveyor type, with budgeting guidance and how to compare vendor quotes.</p>
        </a>

        <a href="/resources/conveyor-design-guide/" class="card group p-6">
          <h3 class="font-display text-lg font-bold tracking-wide text-ink group-hover:text-accent transition-colors mb-2">Design & Sizing Guide</h3>
          <p class="text-base text-ink-muted">Speed calculations, throughput sizing formulas, and conveyor layout planning reference.</p>
        </a>
      </div>

      <div class="mt-5 grid sm:grid-cols-2 md:grid-cols-4 gap-3 font-sans text-sm">
        <a href="/resources/conveyor-belting/" class="flex items-center gap-2 px-4 py-3 border border-border hover:border-accent/30 text-ink-muted hover:text-accent transition-colors">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          Belting Guide
        </a>
        <a href="/resources/conveyor-parts/" class="flex items-center gap-2 px-4 py-3 border border-border hover:border-accent/30 text-ink-muted hover:text-accent transition-colors">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          Parts & Components
        </a>
        <a href="/resources/conveyor-motors-drives/" class="flex items-center gap-2 px-4 py-3 border border-border hover:border-accent/30 text-ink-muted hover:text-accent transition-colors">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          Motors & Drives
        </a>
        <a href="/resources/conveyor-safety/" class="flex items-center gap-2 px-4 py-3 border border-border hover:border-accent/30 text-ink-muted hover:text-accent transition-colors">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          Safety Standards
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="py-16 sm:py-20 bg-surface-dim" aria-labelledby="faq-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 id="faq-heading" class="font-display text-3xl sm:text-4xl font-700 text-ink tracking-wide mb-8">
        Frequently Asked Questions
      </h2>

      <div class="space-y-3">
        <details class="group border border-border bg-surface px-6 py-5 open:pb-6" open>
          <summary class="font-sans text-lg font-semibold text-ink cursor-pointer list-none flex items-center justify-between group-open:mb-3">
            How much does a packaging conveyor system cost?
            <svg class="w-5 h-5 text-ink-muted group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="text-ink-muted leading-relaxed space-y-3">
            <p>Conveyor pricing varies widely based on several key factors. There is no single "price" for a conveyor. Costs depend on your specific application.</p>
            <p><strong class="text-ink">Key cost factors:</strong></p>
            <ul class="list-disc list-inside space-y-1 ml-2">
              <li><strong class="text-ink">Conveyor type:</strong> gravity roller is the least expensive; spiral and pallet conveyors cost significantly more</li>
              <li><strong class="text-ink">Length and width:</strong> longer runs and wider belts increase cost proportionally</li>
              <li><strong class="text-ink">Materials:</strong> food-grade stainless steel costs more than painted carbon steel</li>
              <li><strong class="text-ink">Controls:</strong> PLC-controlled systems with sensors and VFDs add substantial cost vs. simple on/off</li>
              <li><strong class="text-ink">Environment:</strong> washdown, cleanroom, or hazardous-area ratings increase cost</li>
              <li><strong class="text-ink">Installation:</strong> structural supports, electrical, and integration with existing equipment</li>
            </ul>
            <p>The best approach is to contact manufacturers directly with your specific requirements. See our <a href="/resources/conveyor-cost-guide/" class="text-accent font-semibold hover:text-accent-hover">cost factors guide</a> for a detailed breakdown of what drives conveyor pricing.</p>
          </div>
        </details>

        <details class="group border border-border bg-surface px-6 py-5 open:pb-6">
          <summary class="font-sans text-lg font-semibold text-ink cursor-pointer list-none flex items-center justify-between group-open:mb-3">
            What type of conveyor is best for packaging lines?
            <svg class="w-5 h-5 text-ink-muted group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="text-ink-muted leading-relaxed space-y-3">
            <p>The right conveyor depends on your product, throughput, and environment:</p>
            <ul class="list-disc list-inside space-y-1 ml-2">
              <li><a href="/conveyor-types/flat-belt-conveyors/" class="text-accent hover:text-accent-hover font-semibold">Belt conveyors</a>: lightweight products, irregular shapes, gentle handling</li>
              <li><a href="/conveyor-types/roller-conveyors/" class="text-accent hover:text-accent-hover font-semibold">Roller conveyors</a>: cases, cartons, totes (gravity or powered)</li>
              <li><a href="/conveyor-types/mdr-conveyors/" class="text-accent hover:text-accent-hover font-semibold">MDR conveyors</a>: zone-based accumulation, low maintenance, quiet</li>
              <li><a href="/conveyor-types/tabletop-conveyors/" class="text-accent hover:text-accent-hover font-semibold">Tabletop chain</a>: bottles, cans, small cartons at high speed</li>
              <li><a href="/conveyor-types/spiral-conveyors/" class="text-accent hover:text-accent-hover font-semibold">Spiral conveyors</a>: elevation changes without eating floor space</li>
            </ul>
            <p>Most packaging lines combine multiple types. <a href="/conveyor-types/" class="text-accent font-semibold hover:text-accent-hover">Browse all 30+ types</a>.</p>
          </div>
        </details>

        <details class="group border border-border bg-surface px-6 py-5 open:pb-6">
          <summary class="font-sans text-lg font-semibold text-ink cursor-pointer list-none flex items-center justify-between group-open:mb-3">
            What is zero-pressure accumulation?
            <svg class="w-5 h-5 text-ink-muted group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="text-ink-muted leading-relaxed space-y-3">
            <p><strong class="text-ink">Zero-pressure accumulation (ZPA)</strong> means products queue on a conveyor without touching each other or building up backpressure. Each zone has its own photo-eye sensor and independent drive. When a downstream zone is occupied, upstream zones stop their products with controlled gaps between them.</p>
            <p>ZPA prevents product damage, label scuffing, and carton crushing. It's critical for fragile products and high-value items. Most commonly implemented using <a href="/conveyor-types/mdr-conveyors/" class="text-accent hover:text-accent-hover font-semibold">MDR conveyors</a> or <a href="/conveyor-types/accumulation-conveyors/" class="text-accent hover:text-accent-hover font-semibold">pneumatic accumulation conveyors</a>.</p>
          </div>
        </details>

        <details class="group border border-border bg-surface px-6 py-5 open:pb-6">
          <summary class="font-sans text-lg font-semibold text-ink cursor-pointer list-none flex items-center justify-between group-open:mb-3">
            How do I calculate conveyor speed for my line?
            <svg class="w-5 h-5 text-ink-muted group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="text-ink-muted leading-relaxed space-y-3">
            <p>The basic conveyor speed formula:</p>
            <p class="font-mono text-ink bg-surface-dim px-4 py-3 border border-border text-sm"><strong>Speed (FPM) = (Products/min &times; Product length in ft) + gap allowance</strong></p>
            <p>Common packaging line speeds by application:</p>
            <ul class="list-disc list-inside space-y-1 ml-2">
              <li><strong class="text-ink">Case conveyors:</strong> 50-200 FPM</li>
              <li><strong class="text-ink">Bottle lines:</strong> 20-100 FPM</li>
              <li><strong class="text-ink">Pallet conveyors:</strong> 20-60 FPM</li>
              <li><strong class="text-ink">High-speed sortation:</strong> 300-600 FPM</li>
            </ul>
            <p>Always add <strong class="text-ink">10-15% speed headroom</strong> above peak production rate so the conveyor never becomes your bottleneck. See our <a href="/resources/conveyor-design-guide/" class="text-accent font-semibold hover:text-accent-hover">design guide</a> for throughput sizing formulas.</p>
          </div>
        </details>

        <details class="group border border-border bg-surface px-6 py-5 open:pb-6">
          <summary class="font-sans text-lg font-semibold text-ink cursor-pointer list-none flex items-center justify-between group-open:mb-3">
            What is the difference between MDR and powered roller?
            <svg class="w-5 h-5 text-ink-muted group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="text-ink-muted leading-relaxed space-y-3">
            <p><strong class="text-ink">MDR (Motor Driven Roller)</strong> uses small 24VDC brushless motors built inside individual rollers. Each zone (typically 2-5 rollers) operates independently with its own photo-eye and control card. This enables zero-pressure accumulation and zone-by-zone control.</p>
            <p><strong class="text-ink">Powered roller (line-shaft or belt-driven)</strong> uses one external motor driving all rollers through a common belt or chain. All rollers spin together, so there's no zone control without additional pneumatic stops or clutches.</p>
            <p><strong class="text-ink">MDR advantages:</strong> 50%+ energy savings (zones only run when needed), quieter (65 dB vs 80+ dB), less maintenance (no belts/chains to replace), better product protection. <strong class="text-ink">Powered roller advantages:</strong> lower upfront cost, simpler for continuous-flow applications with no accumulation requirement.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

