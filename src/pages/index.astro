---
import BaseLayout from '../layouts/BaseLayout.astro';
const conveyorTypes = [
  { name: 'Roller', slug: 'roller-conveyors', desc: 'Gravity, powered & MDR roller systems', icon: '⊚' },
  { name: 'Accumulation', slug: 'accumulation-conveyors', desc: 'Zero-pressure zone buffering', icon: '⫸' },
  { name: 'Belt', slug: 'flat-belt-conveyors', desc: 'Flat, cleated & modular belt', icon: '▬' },
  { name: 'Transfer', slug: 'transfer-conveyors', desc: 'Right-angle & multi-directional', icon: '⊞' },
  { name: 'Spiral', slug: 'spiral-conveyors', desc: 'Vertical elevation change', icon: '⟳' },
  { name: 'Chain', slug: 'chain-conveyors', desc: 'Drag, slat & overhead chain', icon: '⛓' },
  { name: 'Sortation', slug: 'diverting-merging', desc: 'Diverting & merging systems', icon: '⑂' },
  { name: 'Pallet', slug: '../industries/packaging-line-conveyors/pallet', desc: 'Heavy-duty pallet handling', icon: '⬚' },
  { name: 'Screw', slug: 'screw-conveyors', desc: 'Bulk auger conveying', icon: '⏚' },
  { name: 'Tabletop', slug: 'tabletop-conveyors', desc: 'Bottles, cans & cartons', icon: '⊟' },
  { name: 'Vibratory', slug: 'vibratory-conveyors', desc: 'Parts feeders & hoppers', icon: '∿' },
  { name: 'View All 30+ Types', slug: '', desc: 'Complete conveyor guide', icon: '→' },
];

const industries = [
  { name: 'Food & Beverage', slug: 'food-conveyors', desc: 'Sanitary, USDA, washdown-rated conveyor systems for food processing and packaging lines', tags: ['USDA', '3-A', 'IP69K'], color: 'bg-ink/5 text-ink' },
  { name: 'Packaging Lines', slug: 'packaging-line-conveyors', desc: 'Primary, secondary & tertiary packaging line conveyor integration and layout', tags: ['Case', 'Pallet', 'Wrap'], color: 'bg-ink/5 text-ink' },
  { name: 'Pharmaceutical', slug: 'pharmaceutical-conveyors', desc: 'Cleanroom and GMP-compliant conveyor systems for pharma manufacturing', tags: ['GMP', 'ISO 5-8', 'HEPA'], color: 'bg-ink/5 text-ink' },
  { name: 'Automotive', slug: 'automotive-conveyors', desc: 'Assembly line, paint line & lineside delivery conveyor systems', tags: ['Assembly', 'Paint', 'AGV'], color: 'bg-ink/5 text-ink' },
];

const functions = [
  { name: 'Accumulate & Buffer', slug: 'storage-conveyors', desc: 'Buffer product between processes to absorb line stops' },
  { name: 'Collate & Lane', slug: 'collating-laning', desc: 'Distribute product from one lane across multiple lanes' },
  { name: 'Load Trays', slug: 'tray-loading', desc: 'Automatic tray loading, denesting & unloading' },
  { name: 'Index & Position', slug: 'indexing-conveyors', desc: 'Precision stop-and-go positioning for robotics' },
  { name: 'Reject & Divert', slug: 'reject-systems', desc: 'Remove failed QC product from the main line' },
  { name: 'Turn & Orient', slug: 'product-handling', desc: 'Rotate, flip or invert product on the conveyor' },
];

// FAQ schema — real content for Google + LLMs
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does a packaging conveyor system cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Packaging conveyor system pricing depends on type, length, load capacity, controls, and environment (e.g. food-grade or cleanroom). Gravity roller sections are the lowest cost, while fully integrated packaging lines with PLC controls and sortation are the highest. Key cost factors include conveyor length, belt/roller material, motor type, accumulation features, and installation complexity. Contact manufacturers directly for project-specific quotes."
      }
    },
    {
      "@type": "Question",
      "name": "What type of conveyor is best for packaging lines?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The best conveyor type depends on your product, speed, and application. Belt conveyors work for lightweight and irregular shapes. Roller conveyors (gravity or powered) suit cases and cartons. MDR conveyors provide zone-based accumulation with low maintenance. Tabletop chain conveyors handle bottles and cans. Spiral conveyors save floor space for elevation changes. Most packaging lines use multiple conveyor types together."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between MDR and powered roller conveyors?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "MDR (Motor Driven Roller) conveyors use small brushless DC motors inside individual rollers, controlled in independent zones for zero-pressure accumulation. Powered roller conveyors use a single external motor driving all rollers via belt or chain. MDR is quieter, more energy efficient (50%+ savings), and provides better product control. Powered roller has lower upfront cost and is simpler for continuous-flow applications."
      }
    },
    {
      "@type": "Question",
      "name": "What conveyor speed do I need for my packaging line?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Conveyor speed depends on your throughput requirement. A typical formula: Speed (FPM) = (Products per minute × Product length in feet) + gap allowance. Common packaging line speeds: case conveyors run 50-200 FPM, bottle lines run 20-100 FPM, pallet conveyors run 20-60 FPM. Always add 10-15% speed headroom above your peak production rate to prevent the conveyor from becoming a bottleneck."
      }
    },
    {
      "@type": "Question",
      "name": "What is zero-pressure accumulation on a conveyor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Zero-pressure accumulation (ZPA) means products stop and queue on a conveyor without touching each other or building up backpressure. Each zone has its own sensor and drive control. When a downstream zone is occupied, the upstream zone stops its product with a gap between them. This prevents product damage, label scuffing, and carton crushing. ZPA is critical for fragile products and is most commonly implemented using MDR (Motor Driven Roller) conveyors."
      }
    }
  ]
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Packaging Conveyor Systems — Complete Guide to 30+ Conveyor Types",
  "description": "The packaging industry's most comprehensive conveyor resource. Technical guides, pricing data, and selection criteria for over 30 conveyor types across food, pharmaceutical, automotive, and warehouse applications.",
  "url": "https://packagingconveyor.com/",
  "isPartOf": { "@type": "WebSite", "name": "PackagingConveyor.com", "url": "https://packagingconveyor.com" },
  "about": {
    "@type": "Thing",
    "name": "Packaging Conveyor Systems",
    "description": "Conveyor systems used in packaging operations including belt, roller, MDR, accumulation, spiral, chain, and sortation conveyors"
  }
};
---

<BaseLayout
  title="Packaging Conveyor Systems — Complete Guide to 30+ Types, Pricing & Specs"
  description="The packaging industry's most comprehensive conveyor resource. Technical guides, pricing ranges, and selection criteria for 30+ conveyor types. Free buyer's guide available."
  canonical="https://packagingconveyor.com/"
  schema={[faqSchema, webPageSchema]}
>

  <!-- ═══ HERO ═══ -->
  <section class="bg-blueprint relative overflow-hidden">
    <div class="absolute bottom-0 left-0 right-0 h-12 opacity-20">
      <div class="flex items-center h-full gap-[18px] px-4">
        {Array.from({length: 80}).map(() => (
          <div class="w-3 h-3 rounded-full bg-white/30 flex-shrink-0"></div>
        ))}
      </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-28 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <!-- Left: Message -->
        <div class="animate-fade-in-up">
          <div class="section-label text-accent-bright/80 mb-6">
            The Packaging Conveyor Resource
          </div>
          <h1 class="font-display text-6xl sm:text-7xl lg:text-8xl font-800 text-white tracking-wide uppercase leading-[0.95] mb-8">
            Every<br />
            <span class="text-accent-bright">Conveyor</span><br />
            Type. Explained.
          </h1>
          <p class="text-xl sm:text-2xl text-white/60 max-w-lg mb-10 leading-relaxed">
            Technical guides, pricing ranges, and selection criteria for <strong class="text-white/90">30+ packaging conveyor types</strong>. Built for plant engineers and packaging managers.
          </p>
          <div class="flex flex-wrap gap-8 text-base text-white/60 font-mono">
            <span class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-green"></span>
              30+ conveyor types
            </span>
            <span class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-green"></span>
              Real pricing data
            </span>
            <span class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-green"></span>
              100% free
            </span>
          </div>
        </div>

        <!-- Right: Quick-nav cards -->
        <div class="animate-fade-in-up space-y-4" style="animation-delay: 0.2s">
          <a href="/conveyor-types/" class="block p-6 bg-white/[0.06] border border-white/10 hover:border-accent/40 hover:bg-white/[0.08] transition-all group">
            <div class="font-display text-2xl font-bold uppercase tracking-wider text-white group-hover:text-accent-bright transition-colors mb-2">Browse by Conveyor Type</div>
            <p class="text-base text-white/60">30+ types with specs, pricing, and selection guides</p>
          </a>
          <a href="/industries/" class="block p-6 bg-white/[0.06] border border-white/10 hover:border-accent-bright/40 hover:bg-white/[0.08] transition-all group">
            <div class="font-display text-2xl font-bold uppercase tracking-wider text-white group-hover:text-accent-bright transition-colors mb-2">Browse by Industry</div>
            <p class="text-base text-white/60">Food, packaging, pharma, automotive — find your fit</p>
          </a>
          <a href="/conveyor-functions/" class="block p-6 bg-white/[0.06] border border-white/10 hover:border-accent-bright/40 hover:bg-white/[0.08] transition-all group">
            <div class="font-display text-2xl font-bold uppercase tracking-wider text-white group-hover:text-accent-bright transition-colors mb-2">Browse by Function</div>
            <p class="text-base text-white/60">Accumulate, sort, index, reject — start with what you need</p>
          </a>
          <a href="/resources/conveyor-cost-guide/" class="block p-6 bg-accent-bright/20 border border-accent-bright/30 hover:bg-accent-bright/30 transition-all group">
            <div class="font-display text-2xl font-bold uppercase tracking-wider text-white group-hover:text-accent-bright transition-colors mb-2">Conveyor Pricing Guide</div>
            <p class="text-base text-white/60">Real price ranges for every conveyor type</p>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TRUST BAR ═══ -->
  <section class="bg-ink conveyor-strip relative" aria-label="Site statistics">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 relative z-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <div class="font-display text-3xl sm:text-4xl font-bold text-white tracking-wider">98</div>
          <div class="text-sm text-white/60 font-mono uppercase tracking-wider">In-Depth Guides</div>
        </div>
        <div>
          <div class="font-display text-3xl sm:text-4xl font-bold text-white tracking-wider">30+</div>
          <div class="text-sm text-white/60 font-mono uppercase tracking-wider">Conveyor Types</div>
        </div>
        <div>
          <div class="font-display text-3xl sm:text-4xl font-bold text-accent-bright tracking-wider">4</div>
          <div class="text-sm text-white/60 font-mono uppercase tracking-wider">Industry Verticals</div>
        </div>
        <div>
          <div class="font-display text-3xl sm:text-4xl font-bold text-white tracking-wider">$0</div>
          <div class="text-sm text-white/60 font-mono uppercase tracking-wider">Always Free</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ WHAT IS THIS SITE ═══ -->
  <section class="py-24 bg-surface" aria-labelledby="about-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-label text-accent mb-4">About this resource</div>
      <h2 id="about-heading" class="text-4xl sm:text-5xl font-800 text-ink tracking-wide mb-8">
        The Conveyor Guide That <span class="text-accent">Should Have Existed</span>
      </h2>
      <div class="text-lg text-ink-muted leading-relaxed space-y-4">
        <p>
          If you're specifying a conveyor system for a packaging line, you already know the problem: manufacturer sites only show <em>their</em> products, distributor sites are catalogs with no engineering context, and the rest is SEO spam with no real data.
        </p>
        <p>
          <strong class="text-ink">PackagingConveyor.com is different.</strong> Every page is written with real engineering data — pricing ranges, speed calculations, throughput formulas, selection criteria, and head-to-head comparisons between conveyor types. We cover <strong class="text-ink">30+ conveyor types</strong> across food & beverage, pharmaceutical, automotive, and warehouse applications.
        </p>
        <p>
          Use this site to spec your system, compare options, and build an RFQ you can send to any vendor. No account required. No sales pitch. Just the data you need.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ CONVEYOR TYPES GRID ═══ -->
  <section class="py-24 bg-surface-dim bg-dots" aria-labelledby="types-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12">
        <div>
          <div class="section-label text-accent mb-4">Conveyor Types</div>
          <h2 id="types-heading" class="text-5xl sm:text-6xl font-800 text-ink tracking-wide">
            Browse by <span class="text-accent">Type</span>
          </h2>
        </div>
        <a href="/conveyor-types/" class="text-base font-semibold text-accent hover:text-accent-hover transition-colors flex items-center gap-1">
          View all 30+ types
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 stagger">
        {conveyorTypes.map((type) => (
          <a
            href={type.slug ? `/conveyor-types/${type.slug}/` : '/conveyor-types/'}
            class:list={[
              "card group flex flex-col p-5",
              !type.slug && "bg-accent/5 border-accent/20 hover:bg-accent/10"
            ]}
          >
            <div class="text-3xl mb-3 opacity-60 group-hover:opacity-100 transition-opacity">{type.icon}</div>
            <div class="font-display text-lg font-bold uppercase tracking-wider text-ink group-hover:text-accent transition-colors">{type.name}</div>
            <div class="text-sm text-ink-muted mt-1">{type.desc}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ INDUSTRIES ═══ -->
  <section class="py-24 bg-surface" aria-labelledby="industries-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="section-label justify-center text-accent mb-4">Industries</div>
        <h2 id="industries-heading" class="text-5xl sm:text-6xl font-800 text-ink tracking-wide">
          Conveyors for <span class="text-accent">Your Industry</span>
        </h2>
        <p class="mt-5 text-ink-muted text-lg max-w-2xl mx-auto">
          Every industry has unique requirements — material compatibility, sanitation standards, speed ranges, and compliance certifications. Find conveyors that match yours.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-5 stagger">
        {industries.map((ind) => (
          <a href={`/industries/${ind.slug}/`} class="card group p-7 flex flex-col">
            <div class="flex items-start justify-between mb-3">
              <h3 class="font-display text-2xl font-bold uppercase tracking-wider text-ink group-hover:text-accent transition-colors">{ind.name}</h3>
              <svg class="w-6 h-6 text-ink-muted group-hover:text-accent group-hover:translate-x-1 transition-all flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
            <p class="text-base text-ink-muted mb-5 leading-relaxed">{ind.desc}</p>
            <div class="flex flex-wrap gap-2 mt-auto">
              {ind.tags.map(tag => (
                <span class:list={["text-sm font-semibold px-3 py-1", ind.color]}>{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FUNCTIONS ═══ -->
  <section class="py-24 bg-ink-light" aria-labelledby="functions-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <div class="section-label justify-center text-accent-bright mb-4">Conveyor Functions</div>
        <h2 id="functions-heading" class="text-5xl sm:text-6xl font-800 text-white tracking-wide">
          What Does Your Conveyor<br />Need to <span class="text-accent-bright">Do?</span>
        </h2>
        <p class="mt-5 text-white/60 text-lg max-w-2xl mx-auto">
          Think by problem, not by equipment. Start with the function and we'll walk you through the right conveyor types for the job.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 stagger">
        {functions.map((fn) => (
          <a href={`/conveyor-functions/${fn.slug}/`} class="group p-6 border border-white/10 bg-white/[0.03] hover:bg-white/[0.06] hover:border-accent/40 transition-all">
            <h3 class="font-display text-xl font-bold uppercase tracking-wider text-white group-hover:text-accent-bright transition-colors mb-2">{fn.name}</h3>
            <p class="text-base text-white/60 leading-relaxed">{fn.desc}</p>
          </a>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href="/conveyor-functions/" class="inline-flex items-center gap-2 text-base font-semibold text-accent-bright hover:text-white transition-colors">
          View all conveyor functions
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ QUICK REFERENCE: CONVEYOR COMPARISON ═══ -->
  <section class="py-24 bg-surface" aria-labelledby="comparison-heading">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="section-label text-accent mb-4">Quick Reference</div>
      <h2 id="comparison-heading" class="text-4xl sm:text-5xl font-800 text-ink tracking-wide mb-10">
        Conveyor Type <span class="text-accent">Comparison</span>
      </h2>

      <div class="overflow-x-auto -mx-4 px-4">
        <table class="w-full text-left border-collapse min-w-[700px]">
          <thead>
            <tr class="border-b-2 border-ink">
              <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4 pr-4">Type</th>
              <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4 pr-4">Best For</th>
              <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4 pr-4">Speed Range</th>
              <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4 pr-4">Relative Cost</th>
              <th class="font-display text-base font-bold uppercase tracking-wider text-ink py-4">Load</th>
            </tr>
          </thead>
          <tbody class="text-base text-ink-muted">
            <tr class="border-b border-border">
              <td class="py-4 pr-4 font-semibold text-ink"><a href="/conveyor-types/flat-belt-conveyors/" class="text-accent hover:text-accent-hover">Belt</a></td>
              <td class="py-4 pr-4">Lightweight, irregular shapes</td>
              <td class="py-4 pr-4 font-mono text-sm">20–400 FPM</td>
              <td class="py-4 pr-4 font-mono text-sm">$$</td>
              <td class="py-4 font-mono text-sm">Up to 100 lbs</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-4 pr-4 font-semibold text-ink"><a href="/conveyor-types/roller-conveyors/" class="text-accent hover:text-accent-hover">Gravity Roller</a></td>
              <td class="py-4 pr-4">Cases, cartons, totes</td>
              <td class="py-4 pr-4 font-mono text-sm">Gravity</td>
              <td class="py-4 pr-4 font-mono text-sm">$</td>
              <td class="py-4 font-mono text-sm">Up to 200 lbs</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-4 pr-4 font-semibold text-ink"><a href="/conveyor-types/roller-conveyors/" class="text-accent hover:text-accent-hover">Powered Roller</a></td>
              <td class="py-4 pr-4">Continuous flow, cases</td>
              <td class="py-4 pr-4 font-mono text-sm">30–200 FPM</td>
              <td class="py-4 pr-4 font-mono text-sm">$$$</td>
              <td class="py-4 font-mono text-sm">Up to 500 lbs</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-4 pr-4 font-semibold text-ink"><a href="/conveyor-types/mdr-conveyors/" class="text-accent hover:text-accent-hover">MDR</a></td>
              <td class="py-4 pr-4">Accumulation, zone control</td>
              <td class="py-4 pr-4 font-mono text-sm">30–180 FPM</td>
              <td class="py-4 pr-4 font-mono text-sm">$$$</td>
              <td class="py-4 font-mono text-sm">Up to 250 lbs</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-4 pr-4 font-semibold text-ink"><a href="/conveyor-types/spiral-conveyors/" class="text-accent hover:text-accent-hover">Spiral</a></td>
              <td class="py-4 pr-4">Elevation change, small footprint</td>
              <td class="py-4 pr-4 font-mono text-sm">50–200 FPM</td>
              <td class="py-4 pr-4 font-mono text-sm">$$$$</td>
              <td class="py-4 font-mono text-sm">Up to 75 lbs</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-4 pr-4 font-semibold text-ink"><a href="/conveyor-types/tabletop-conveyors/" class="text-accent hover:text-accent-hover">Tabletop Chain</a></td>
              <td class="py-4 pr-4">Bottles, cans, small cartons</td>
              <td class="py-4 pr-4 font-mono text-sm">20–100 FPM</td>
              <td class="py-4 pr-4 font-mono text-sm">$$</td>
              <td class="py-4 font-mono text-sm">Up to 50 lbs</td>
            </tr>
            <tr>
              <td class="py-4 pr-4 font-semibold text-ink"><a href="../industries/packaging-line-conveyors/pallet" class="text-accent hover:text-accent-hover">Pallet</a></td>
              <td class="py-4 pr-4">Heavy palletized loads</td>
              <td class="py-4 pr-4 font-mono text-sm">20–60 FPM</td>
              <td class="py-4 pr-4 font-mono text-sm">$$$$</td>
              <td class="py-4 font-mono text-sm">Up to 4,000 lbs</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="text-sm text-ink-muted mt-4">Relative cost: $ = lowest, $$$$ = highest. Actual pricing varies significantly by length, configuration, materials, and manufacturer. <a href="/resources/conveyor-cost-guide/" class="text-accent hover:text-accent-hover font-semibold">See our cost factors guide</a>.</p>
    </div>
  </section>

  <!-- ═══ START HERE ═══ -->
  <section class="py-24 bg-ink-light" aria-labelledby="start-heading">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
