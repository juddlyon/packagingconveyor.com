---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  schema?: object[];
  robots?: string;
  ogImage?: string;
}

const { title, description = "The packaging industry's most comprehensive conveyor resource. Technical guides, selection criteria, and encyclopedic coverage of 30+ conveyor types.", canonical, schema = [], robots = "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1", ogImage } = Astro.props;
const siteUrl = 'https://packagingconveyor.com';
const currentPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/';
const pageUrl = canonical || `${siteUrl}${currentPath}`;
const pageOgImage = ogImage || `${siteUrl}/og-image.svg`;

// Default org + website schema on every page
const defaultSchema = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "PackagingConveyor.com",
    "url": siteUrl,
    "description": "Technical guides and selection criteria for 30+ packaging conveyor types across food, pharmaceutical, automotive, and warehouse applications.",
    "areaServed": "US"
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "PackagingConveyor.com",
    "url": siteUrl,
    "description": description
  }
];

const allSchema = [...defaultSchema, ...schema];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={pageUrl} />

  <!-- SEO: robots -->
  <meta name="robots" content={robots} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@400;600;700;800&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={pageUrl} />
  <meta property="og:site_name" content="PackagingConveyor.com" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={pageOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={pageOgImage} />

  <!-- Structured Data -->
  {allSchema.map(s => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
